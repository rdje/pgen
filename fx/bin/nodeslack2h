sub merge {
 print "(nodeslack2h) -I- Merging..\n";
 HUtils::recurse($_[0], \&do_merge);
}

sub do_merge {
my ($info, $scalar) = @_;

 my $merged_join     = q($merged{').join(q('}{'), @$info).q('});
 eval qq(my \$prev_merged_v = $merged_join; $merged_join = defined(\$prev_merged_v) && ($scalar > \$prev_merged_v) ? \$prev_merged_v : $scalar);
}

sub do_diff {
my ($info, $scalar) = @_;

 my $merged_join     = q($merged{').join(q('}{'), @$info).q('});
 if ((my $val = eval($merged_join)) != $scalar) {
   print "@$info HAS DIFFERENT VALUES ($val) ($scalar)\n";
 }
}

sub group_by {
my $gb = shift;

 my $idx = 0;
 my @group_o;
 my @subgrp;
 foreach (@_) {
  if(@subgrp && ($idx % $gb == 0) && int($idx/$gb)) {
   push @group_o, [@subgrp];

   #print "GROUP DONE(".int($idx/$gb)."):\n  ".join("\n ", @subgrp)."\n\n";

   @subgrp = ();
  }

  push @subgrp, $_;
  #print "(pushed) $_\n";

  ++$idx;
 }

 push @group_o, [@subgrp] if @subgrp;
 
 return @group_o
}

sub get_min {my ($info, $minlist) = @_; (sort {$a <=> $b} @$minlist)[0]}
