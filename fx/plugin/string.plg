var_subst  {
my ($string, $subst_re, %subst_data) = @_;

 sub {local $_ = shift; my %h = map {!ref($_) ? $_ : (ref eq 'HASH' ? %$_ : @$_)} @_; s{$subst_re}{$h{$1} || $1}ge; s/"/\\"/go; eval(qq("$_"))} -> ($string, %subst_data);
}

