var_subst_test {
  open (my $f, $_[0]{_argv}[0]); local $/; my $file = <$f>;
 Global->set ('cgi') = HUtils::Conf(PathSearch->go('cgi'));
  
  set_http_localhost ();
  my $fo = PPlugin->exec('file_list_path2http', $file);

  print "var_subst_test: ($fo)\n";
}
