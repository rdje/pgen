dutycycled {
my ($conf) = @_;

 stan_backend_start ($conf); 

 my $filtered           = HUtils::GenericFilter($conf, TcFlow::GetAll($conf->{_argv}), "$conf->{_action}_sequence",  maptable=>'reportiming');
 my $arrival_time_index = TableGrep::IndexOf("arrival_time");


 my $wbname = $conf->{_excelfile} || "$conf->{_action}.xls";

}
