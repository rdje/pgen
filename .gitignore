# =============================================================================
# Multi-Language Parser Generator Project .gitignore
# Languages: Perl, Rust, Julia, Zig, Go, Python + General Development
# =============================================================================

# =============================================================================
# RUST
# =============================================================================
# Compiled files
target/
Cargo.lock
*.pdb

# Generated by Cargo
# will have compiled files and executables
debug/
release/

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc may generate these, which store debugging information
*.pdb

# Rust backup files and development artifacts
*.rs.bak
*.rs.bak2
*.rs.orig

# Rust test artifacts
test_*.json
regex_test.json
test_grammar.json

# Generated test binaries
test_minimal_parser

# Rust stress test artifacts
*_stress_test_*.log
comprehensive_stress_test_*.log
parser_stress_test_*.log

# Generated debug log files from --debug option
*_test_*.log
*_stress_test_*.log
semantic_annotation_*.log
return_annotation_*.log
regex_*.log

# Test automation system files
test_registry.json
*.auto-sync
Makefile.auto-sync.timestamp
.sync_*
sync_status_*

# =============================================================================
# JULIA  
# =============================================================================
# Julia compiled files
*.ji
*.so
*.dylib
*.dll

# Julia package manager
Manifest.toml
**/Manifest.toml

# Julia environment
.julia/
deps/deps.jl

# Julia temporary files
*.jl.cov
*.jl.*.cov
*.jl.mem
*.jl.*.mem

# Julia documentation build
docs/build/
docs/site/

# =============================================================================
# ZIG
# =============================================================================
# Zig build artifacts
.zig-cache/
zig-out/
zig-cache/

# Zig compiled binaries
*.exe
*.obj
*.o
*.lib
*.a
*.so
*.dylib
*.dll

# Zig build files (keep build.zig)
build.zig.zon

# Zig test outputs
test_*.zig
!*_test.zig

# =============================================================================
# GO
# =============================================================================
# Go compiled binaries
*.exe
*.exe~
*.dll
*.so
*.dylib

# Go test binary, built with `go test -c`
*.test

# Go coverage files
*.out
*.prof

# Go vendor directory
vendor/

# Go module cache
go.sum

# =============================================================================
# PYTHON
# =============================================================================
# Python compiled files
__pycache__/
*.py[cod]
*$py.class

# Python distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
PIPFILE.lock

# Python virtual environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# Python testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# Python IDEs
.spyderproject
.spyproject
.rope_project

# =============================================================================
# PERL
# =============================================================================
# Perl compiled modules
*.pm.bak
*.pl.bak
blib/
pm_to_blib
MYMETA.*
META.*
Build
_build/

# Perl temporary files
*~
*.tmp
*.temp

# Perl test files
cover_db/
nytprof.out
nytprof/

# =============================================================================
# PARSER GENERATED FILES
# =============================================================================
# Generated parsers / artifacts
# `generated/` is intentionally version controlled by repository policy.
**/target/
generated_*.pm
generated_*.jl
generated_*.rs
perl/*parser.rs
*_parser.pm
*_parser.jl

# Parser test outputs
parse_results/
test_outputs/
*.parse_log
*.parser_debug

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
# Editor files
.vscode/
.idea/

# Vim files
*.swp
*.swo
*.sw?
*.un~
Session.vim
.netrwhist

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
debug.log
error.log
parser.log
rust/regression_logs/

# Parser debug and trace logs
parser_debug_*.log
trace_output_*.log
stress_test_results_*.log

# Temporary files
tmp/
temp/
*.tmp
*.temp
.cache/

# =============================================================================
# BUILD & COMPILATION
# =============================================================================
# Build artifacts
build/
dist/
out/

# Configuration files (keep templates, ignore local configs)
config.local.*
local_config.*
.env.local

# =============================================================================
# TESTING & BENCHMARKING  
# =============================================================================
# Test results
test_results/
benchmark_results/
*.test_output
*.benchmark
coverage/

# Test automation and synchronization
test_sync_status/
auto_sync_logs/
sync_tests_output/
test_automation_*.log
individual_tests_*.rs

# Performance profiling
*.prof
*.profile
perf.data*
callgrind.out.*

# =============================================================================
# DOCUMENTATION
# =============================================================================
# Generated documentation (keep source docs)
doc/build/
docs/_build/
*.pdf
*.html
!README.html
!docs/**/*.html

# Documentation processing artifacts
docs/.buildinfo
docs/.doctrees/
*.md.backup
*.md.tmp

# =============================================================================
# SYSTEM & OS
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
.nfs*

# =============================================================================
# GIT & VERSION CONTROL
# =============================================================================
# Git files to ignore
*.orig
*.rej
.git-blame-ignore-revs

# =============================================================================
# EXCEPTIONS (Files to always include)
# =============================================================================
# Keep important config templates
!config.template.*
!example.config.*

# Keep grammar files (these are source, not generated)
!*.ebnf
!*.bnf
!*.grammar

# Keep documentation
!README.*
!CHANGELOG.*
!LICENSE*
!docs/**/*.md

# Keep essential scripts
!build.sh
!install.sh
!run_tests.sh

# Keep stress test source files (these are part of the codebase)
!*_stress_test.rs
!stress_test_*.rs

# Keep test automation system source files
!sync_tests.rs
!test_automation_demo.rs
!Makefile.auto-sync

# Test runner logs
test_runner_*.log
universal_test_runner_*.log

# Repository policy: keep the full generated tree in git.
!generated/
!generated/**
