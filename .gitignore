# =============================================================================
# Multi-Language Parser Generator Project .gitignore
# Languages: Perl, Rust, Julia + General Development
# =============================================================================

# =============================================================================
# RUST
# =============================================================================
# Compiled files
target/
Cargo.lock
*.pdb

# Generated by Cargo
# will have compiled files and executables
debug/
release/

# Backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc may generate these, which store debugging information
*.pdb

# =============================================================================
# JULIA  
# =============================================================================
# Julia compiled files
*.ji
*.so
*.dylib
*.dll

# Julia package manager
Manifest.toml
**/Manifest.toml

# Julia environment
.julia/
deps/deps.jl

# Julia temporary files
*.jl.cov
*.jl.*.cov
*.jl.mem
*.jl.*.mem

# Julia documentation build
docs/build/
docs/site/

# =============================================================================
# PERL
# =============================================================================
# Perl compiled modules
*.pm.bak
*.pl.bak
blib/
pm_to_blib
MYMETA.*
META.*
Build
_build/

# Perl temporary files
*~
*.tmp
*.temp

# Perl test files
cover_db/
nytprof.out
nytprof/

# =============================================================================
# PARSER GENERATED FILES
# =============================================================================
# Generated parsers (preserve source grammars, ignore generated code)
**/generated/
**/target/
generated_*.pm
generated_*.jl
generated_*.rs
*_parser.pm
*_parser.jl
*_parser.rs

# Parser test outputs
parse_results/
test_outputs/
*.parse_log
*.parser_debug

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
# Editor files
.vscode/
.idea/

# Vim files
*.swp
*.swo
*.sw?
*.un~
Session.vim
.netrwhist

# Development notes and commit messages
git_message_brief.txt

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
debug.log
error.log
parser.log

# Temporary files
tmp/
temp/
*.tmp
*.temp
.cache/

# =============================================================================
# BUILD & COMPILATION
# =============================================================================
# Build artifacts
build/
dist/
out/

# Configuration files (keep templates, ignore local configs)
config.local.*
local_config.*
.env.local

# =============================================================================
# TESTING & BENCHMARKING  
# =============================================================================
# Test results
test_results/
benchmark_results/
*.test_output
*.benchmark
coverage/

# Performance profiling
*.prof
*.profile
perf.data*
callgrind.out.*

# =============================================================================
# DOCUMENTATION
# =============================================================================
# Generated documentation (keep source docs)
doc/build/
docs/_build/
*.pdf
*.html
!README.html
!docs/**/*.html

# =============================================================================
# SYSTEM & OS
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~
.nfs*

# =============================================================================
# GIT & VERSION CONTROL
# =============================================================================
# Git files to ignore
*.orig
*.rej
.git-blame-ignore-revs

# =============================================================================
# EXCEPTIONS (Files to always include)
# =============================================================================
# Keep important config templates
!config.template.*
!example.config.*

# Keep grammar files (these are source, not generated)
!*.ebnf
!*.bnf
!*.grammar

# Keep documentation
!README.*
!CHANGELOG.*
!LICENSE*
!docs/**/*.md

# Keep essential scripts
!build.sh
!install.sh
!run_tests.sh
