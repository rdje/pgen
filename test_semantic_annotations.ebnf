# Test file for semantic annotations
# Testing semantic annotation preservation through transformation pipeline

# Example 1: Simple semantic annotation
@type: "Expression"
@category: "arithmetic"
expression := term (("+" | "-") term)*

# Example 2: Multiple semantic annotations
@input_type: "string"
@min_length: 3
@max_length: 100
@pattern: "alphanumeric"
identifier := /([a-zA-Z_][a-zA-Z0-9_]*)/

# Example 3: Complex structured annotation
@precedence: {level: 5, associativity: "left"}
@complexity: "O(1)"
@pure: true
term := factor (("*" | "/") factor)*

# Example 4: Data generation constraints
@range: {min: 0, max: 1000}
@distribution: "uniform"
@examples: [42, 123, 999]
number := /(\d+)/

# Example 5: Boolean with semantic hints
@default: false
@description: "Feature flag for advanced parsing"
@category: "configuration"
boolean_flag := ("true" | "false")

# Example 6: String with validation rules
@format: "email"
@validation: {regex: "^[\\w.-]+@[\\w.-]+\\.[a-zA-Z]{2,}$"}
@examples: ["user@example.com", "test@domain.org"]
email_address := /"([^"\\]|\\.)*"/
