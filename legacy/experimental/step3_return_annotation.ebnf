# Step 3: Add simple objects

return_annotation := '->' /\s*/ return_expression

return_expression := quantified_array | simple_array | simple_object | scalar_ref

# Arrays (working from step 2)
quantified_array := '[' /\s*/ scalar_ref /\s*/ ']' quantifier -> {type: "array", element: $3, quantified: $6}
simple_array := '[' /\s*/ scalar_ref /\s*/ ']' -> {type: "array", element: $3}

# Simple objects: {key: $1}, {type: "value"}  
simple_object := '{' /\s*/ object_key /\s*/ ':' /\s*/ object_value /\s*/ '}' -> {type: "object", key: $3, value: $7}

object_key := identifier | quoted_string

object_value := scalar_ref | literal

# Literals
literal := quoted_string | number

# Basic elements with proper capturing groups
scalar_ref := '$' number -> {type: "scalar_ref", index: $2}
quantifier := /([\*\+\?])/ -> $1
quoted_string := /"([^"]*)"/ -> $1
number := /(\d+)/ -> $1
identifier := /([a-zA-Z_]\w*)/ -> $1
