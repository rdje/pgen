# Test quantified expressions with return annotations
# These patterns are critical for HDL parsing

# Basic quantifiers with collection
item_list := item+ -> [$1*]
optional_item := item? -> $1
zero_or_more := item* -> [$1*]

# Nested quantifiers
grouped_items := (item | other)+ -> [$1*]
optional_group := (item item)? -> $1

# Base items
item := 'token' -> "item_value"
other := 'alt' -> "other_value"

# Complex HDL-style patterns  
port_list := port+ -> [$1*]
signal_decl := signal* -> [$1*]

port := identifier ':' direction -> {name: $1, dir: $3}
signal := identifier ':' signal_type -> {name: $1, type: $3}

identifier := /([a-zA-Z_][a-zA-Z0-9_]*)/ -> $1
direction := 'in' -> "input" | 'out' -> "output"
signal_type := 'std_logic' -> "logic" | 'integer' -> "int"

