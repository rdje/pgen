# Test cases for deep nesting support in return annotations
# Target: Nested objects with quantified arrays

# Simple nested object (single level) - this is the target pattern
simple_nested := header item* footer -> {data: {items: [$2*]}}

# More complex nesting (multiple levels)
complex_nested := type name body* -> {meta: {type: $1, name: $2}, content: {items: [$3*]}}

# Mixed nesting with arrays of objects  
mixed_structure := title entry* summary -> {document: {title: $1, entries: [{text: $2*}], meta: {summary: $3}}}

# Deeply nested example
deep_example := category subcategory item* tag* -> {classification: {primary: $1, secondary: $2, data: {items: [$3*], metadata: {tags: [$4*]}}}}

# Test terminals
header := /(header)/ -> $1
item := /(item)/ -> $1  
footer := /(footer)/ -> $1
type := /(type)/ -> $1
name := /(name)/ -> $1
body := /(body)/ -> $1
title := /(title)/ -> $1
entry := /(entry)/ -> $1
summary := /(summary)/ -> $1
category := /(category)/ -> $1
subcategory := /(subcategory)/ -> $1
tag := /(tag)/ -> $1
