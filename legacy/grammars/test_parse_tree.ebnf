# Grammar for multi-level parse trees
program := statement* -> [$1]
statement := assignment | expression -> $1
assignment := identifier '=' expression -> {type: "assignment", var: $1, value: $3}
expression := term ('+' term)* -> {type: "expression", left: $1, operators: $2}
term := factor ('*' factor)* -> {type: "term", left: $1, operators: $2}
factor := number | identifier | '(' expression ')' -> $1
number := /\d+/ -> {type: "number", value: $1}
identifier := /[a-zA-Z]\w*/ -> {type: "identifier", name: $1}

