# Complex grammar constructs test
# Tests nested rules, optional elements, quantifiers, and recursion together

# Nested arithmetic with optional parentheses and multiple operators
expression := term (('+'|'-') term)* -> {type: "expression", terms: [$1, $2*]}
term := factor (('*'|'/') factor)* -> {type: "term", factors: [$1, $2*]}
factor := '(' expression ')' -> $2
factor := number -> $1
factor := variable -> $1

# Left-recursive list with optional separators and nested elements
list := list ',' element -> {type: "list", items: [$1, $3]}
list := element -> {type: "singleton", item: $1}
element := '[' list? ']' -> {type: "nested_list", content: $2}
element := /(\w+)/ -> {type: "identifier", name: $1}
element := /(\d+)/ -> {type: "number", value: $1}

# Optional and quantified elements with recursion
statement := assignment ';'? -> $1
statement := block -> $1
assignment := variable '=' expression -> {type: "assignment", var: $1, expr: $3}
block := '{' statement* '}' -> {type: "block", statements: [$2*]}

# Complex nested structures
function_def := 'function' /(\w+)/ '(' parameter_list? ')' block -> {type: "function", name: $2, params: $4, body: $6}
parameter_list := parameter (',' parameter)* -> [$1, $2*]
parameter := /(\w+)/ (':' type)? -> {name: $1, type: $3}

# Variables and basic types
variable := /([a-zA-Z_]\w*)/ -> $1
number := /(\d+)/ -> $1
type := /(\w+)/ -> $1

