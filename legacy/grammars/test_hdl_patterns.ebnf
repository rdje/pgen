# Test HDL-style grammar patterns
hdl_file := entity_decl architecture_body -> {entity: $1, architecture: $2}

entity_decl := /entity/ identifier /is/ port_clause? /end/ /entity/ identifier? /;/ -> {type: "entity", name: $2, ports: $4}

port_clause := /port/ /\(/ port_list /\)/ /;/ -> $3

port_list := port_decl (/;/ port_decl)* -> [$1, $2*]

port_decl := identifier_list /:/ mode signal_type -> {names: $1, mode: $3, type: $4}

identifier_list := identifier (/,/ identifier)* -> [$1, $2*]

architecture_body := /architecture/ identifier /of/ identifier /is/ declaration_list? /begin/ statement_list /end/ /architecture/ identifier? /;/ -> {type: "architecture", name: $2, entity: $4, declarations: $6, statements: $8}

declaration_list := declaration+

statement_list := statement+

declaration := signal_decl -> $1

statement := assignment -> $1

signal_decl := /signal/ identifier_list /:/ signal_type /;/ -> {type: "signal", names: $2, signal_type: $4}

assignment := identifier /<==/ expression /;/ -> {type: "assignment", target: $1, value: $3}

expression := identifier -> $1

mode := /in/ -> "in"
mode := /out/ -> "out"
mode := /inout/ -> "inout"

signal_type := /std_logic/ -> "std_logic"
signal_type := /std_logic_vector/ -> "std_logic_vector"

identifier := /([a-zA-Z][a-zA-Z0-9_]*)/ -> $1

