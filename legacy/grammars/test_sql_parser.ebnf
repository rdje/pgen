# SQL SELECT Parser
sql := select_stmt -> $1

select_stmt := /SELECT/i field_list /FROM/i table_name where_clause? -> {type: "select", fields: $2, table: $4, where: $5}

field_list := field (/,/ field)* -> [$1, $2*]
field_list := /\*/ -> {type: "all_fields"}

field := /([a-zA-Z_][a-zA-Z0-9_]*)/ -> {type: "field", name: $1}

table_name := /([a-zA-Z_][a-zA-Z0-9_]*)/ -> {type: "table", name: $1}

where_clause := /WHERE/i condition -> {type: "where", condition: $2}

condition := field /=/ value -> {type: "equals", field: $1, value: $3}

value := string -> $1
value := number -> $1

string := /'([^']*)'/ -> {type: "string", value: $1}
number := /(\d+)/ -> {type: "number", value: $1}

