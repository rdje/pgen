# Test Quantified Arrays in Self-Hosting Parser

# Simple quantified collection
list_items := item* -> [$1*]

# Multi-element with quantified collection  
data_set := header item* footer -> {header: $1, items: [$2*], footer: $3}

# Basic terminals
item := /(\w+)/ -> $1
header := /(BEGIN)/ -> $1  
footer := /(END)/ -> $1

