# Intermediate Return Annotation DSL
# Step-by-step upgrade from bootstrap to full version

# Main entry point
return_annotation := '->' /\s*/ return_expression

# Core expression types (add complexity gradually)
return_expression := simple_array | simple_object | scalar_ref | literal

# Simple arrays: [$1], [$1*]
simple_array := '[' /\s*/ array_element /\s*/ ']' quantifier? -> {type: "array", element: $3, quantified: $6}

array_element := scalar_ref | literal

# Simple objects: {key: $1}, {type: "value"}
simple_object := '{' /\s*/ object_key ':' /\s*/ object_value /\s*/ '}' -> {type: "object", key: $3, value: $6}

object_key := identifier | quoted_string

object_value := scalar_ref | literal

# Scalar references: $1, $2 (no dot notation yet)
scalar_ref := '$' number -> {type: "scalar_ref", index: $2}

# Simple quantifiers: *, +, ?
quantifier := /[\*\+\?]/ -> $1

# Literals
literal := quoted_string | number

quoted_string := /"([^"]*)"/ -> $1

number := /(\d+)/ -> $1

identifier := /([a-zA-Z_]\w*)/ -> $1

