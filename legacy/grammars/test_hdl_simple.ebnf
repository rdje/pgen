# Simple HDL test focusing on core constructs
simple_entity := /entity/ identifier /is/ /end/ /;/ -> {name: $2}

# Test optional elements
optional_test := identifier port_clause? -> {name: $1, ports: $2}
port_clause := /port/ /\(/ /\)/ -> "empty_ports"

# Test alternatives
mode := /in/ -> "input"
mode := /out/ -> "output"

# Test quantifiers with return annotations
id_list := identifier (/,/ identifier)* -> [$1, $2*]

identifier := /([a-zA-Z][a-zA-Z0-9_]*)/ -> $1

