# Practical Test of Self-Hosting Return Annotation Parser
# This tests the patterns we've successfully implemented

# Simple scalar return
simple_value := 'hello' -> $1

# Simple array
simple_list := word word -> [$1, $2]

# Multi-element array (our breakthrough!)
triple_list := word word word -> [$1, $2, $3]

# Single-property object
simple_obj := key value -> {key: $1, value: $2}

# Multi-property object (enhanced feature!)
person := name age location -> {name: $1, age: $2, location: $3}

# Complex multi-property with literals
config := name port debug -> {
    service_name: $1,
    port_number: $2,
    debug_enabled: $3,
    version: "1.0"
}

# Basic terminals with capturing groups
word := /(\w+)/ -> $1
name := /([A-Z][a-z]+)/ -> $1
key := /([a-z_]+)/ -> $1
value := /([0-9]+)/ -> $1
age := /([0-9]+)/ -> $1
location := /([A-Z][a-z]+)/ -> $1
port := /([0-9]+)/ -> $1
debug := /(true|false)/ -> $1

