# Systematic EBNF construct validation
# Testing each construct with return annotations

# Test 1: Optional quantifier (?)
optional_test := item? -> $1
item := 'x' -> "found_x"

# Test 2: Zero or more quantifier (*)  
star_test := item* -> [$1*]

# Test 3: One or more quantifier (+)
plus_test := item+ -> [$1*]

# Test 4: OR alternatives with different return types
or_test := 'a' -> "letter_a"
or_test := 'b' -> "letter_b"
or_test := /\d+/ -> {type: "number", value: $1}

# Test 5: Sequences with return annotations
sequence_test := 'start' /\s+/ item /\s+/ 'end' -> {prefix: $1, content: $3, suffix: $5}

# Test 6: Grouping with quantifiers
group_test := ('x' | 'y')+ -> [$1*]

# Test 7: Nested structures
nested_test := group_test /\s*/ optional_test -> {groups: $1, optional: $3}

