/// Parser state
pub struct Parser<'a> {{
    input: &'a str,
    position: usize,
}}

impl<'a> Parser<'a> {{
    /// Create a new parser
    pub fn new(input: &'a str) -> Self {{
        Parser {{ input, position: 0 }}
    }}
    
    /// Get current position
    pub fn position(&self) -> usize {{
        self.position
    }}
    
    /// Check if at end of input
    pub fn is_at_end(&self) -> bool {{
        self.position >= self.input.len()
    }}
    
    /// Peek at current character without consuming
    pub fn peek(&self) -> Option<char> {{
        self.input.chars().nth(self.position)
    }}
    
    /// Advance position and return current character
    pub fn advance(&mut self) -> Option<char> {{
        let ch = self.peek();
        if ch.is_some() {{
            self.position += 1;
        }}
        ch
    }}
    
    /// Match exact string
    pub fn match_string(&mut self, expected: &str) -> ParseResult<()> {{
        let start_pos = self.position;
        
        for expected_char in expected.chars() {{
            match self.advance() {{
                Some(ch) if ch == expected_char => continue,
                Some(ch) => {{
                    self.position = start_pos; // Backtrack
                    return Err(ParseError {{
                        message: format!("Expected '{{}}', found '{{}}'", expected_char, ch),
                        position: self.position,
                        expected: vec![expected.to_string()],
                    }});
                }}
                None => {{
                    self.position = start_pos; // Backtrack  
                    return Err(ParseError {{
                        message: format!("Unexpected end of input, expected '{{}}'", expected),
                        position: self.position,
                        expected: vec![expected.to_string()],
                    }});
                }}
            }}
        }}
        
        Ok(())
    }}
    
    /// Skip whitespace
    pub fn skip_whitespace(&mut self) {{
        while let Some(ch) = self.peek() {{
            if ch.is_whitespace() {{
                self.advance();
            }} else {{
                break;
            }}
        }}
    }}
"#, grammar_name.to_uppercase()));

    // Generate parsing functions for each rule
    for (rule_name, ast_node) in grammar {
        let function_code = generate_parse_function(rule_name, ast_node)?;
