//! # Rust Parser Generator - Complete 5-Stage AST Transformation Pipeline
//! 
//! Generates Rust parser code from JSON raw AST using the exact 5-step transformation pipeline.
//! Strictly follows algorithms specified in docs/ast_transformation_pipeline.md
//! 
//! ## Usage
//! 
//! ```bash
//! rust_parser_gen [options] <json_file>
//! ebnf_to_json.pl grammar.ebnf | rust_parser_gen [options]
//! ```
//! 
//! ## Architecture
//! 
//! Implements the complete 5-step transformation pipeline exactly as documented:
//! 
//! ```
//! Raw AST JSON → Step 2 → Step 2.5 → Step 3 → Step 4 → Step 5 → Rust Parser
//!                Group    Handle      Parse    Handle    Build
//!                by OR    Parens      Sequences Quantifiers Tree
//! ```
//! 
//! Every step follows the algorithms in docs/ast_transformation_pipeline.md precisely.

use serde_json::Value;
use std::collections::HashMap;
use std::env;
use std::fs;
use std::io::{self, Read};
use std::process;
use regex::Regex;

/// Main entry point
fn main() {
    let args: Vec<String> = env::args().collect();
    let options = parse_args(&args);
    let quiet = options.quiet;
    
    match run_generator(options) {
        Ok(_) => {
            if !quiet {
                eprintln!("🎉 Rust parser generated successfully!");
            }
        }
        Err(e) => {
            eprintln!("🚨 RUST PARSER GENERATION FAILED!");
            eprintln!("{}", e);
            process::exit(1);
        }
    }
}

/// Command line options
#[derive(Debug, Clone)]
struct Options {
    input_file: Option<String>,
    output_file: Option<String>,
    module_name: Option<String>, 
    quiet: bool,
    help: bool,
}

impl Default for Options {
    fn default() -> Self {
        Options {
            input_file: None,
            output_file: None,
            module_name: None,
            quiet: false,
            help: false,
        }
    }
}

/// Parse command line arguments
fn parse_args(args: &[String]) -> Options {
    let mut options = Options::default();
    let mut i = 1;
    
    while i < args.len() {
        match args[i].as_str() {
            "--output" | "-o" => {
                if i + 1 < args.len() {
                    options.output_file = Some(args[i + 1].clone());
                    i += 2;
                } else {
                    eprintln!("Error: --output requires a value");
                    process::exit(1);
                }
            }
            "--module" | "-m" => {
                if i + 1 < args.len() {
                    options.module_name = Some(args[i + 1].clone());
                    i += 2;
                } else {
                    eprintln!("Error: --module requires a value");
                    process::exit(1);
                }
            }
            "--quiet" | "-q" => {
                options.quiet = true;
                i += 1;
            }
            "--help" | "-h" => {
                options.help = true;
                i += 1;
            }
            arg if !arg.starts_with('-') => {
                options.input_file = Some(arg.to_string());
                i += 1;
            }
            _ => {
                eprintln!("Unknown option: {}", args[i]);
                process::exit(1);
            }
        }
    }
    
    if options.help {
        print_help();
        process::exit(0);
    }
    
    options
}

