/// Generate a parsing function for an AST node
fn generate_parse_function(rule_name: &str, ast_node: &ASTNode) -> Result<String, Box<dyn std::error::Error>> {
    let mut code = format!("    /// Parse {} rule\n", rule_name);
    code.push_str(&format!("    pub fn parse_{}(&mut self) -> ParseResult<String> {{\n", rule_name));
    code.push_str("        self.skip_whitespace();\n");
    code.push_str(&format!("        let start_pos = self.position;\n"));
    
    match ast_node {
        ASTNode::Terminal(value) => {
            let escaped_value = value.replace('"', "\\\"");
            code.push_str(&format!(r#"        
        self.match_string("{}")?;
        Ok("{}".to_string())
"#, escaped_value, escaped_value));
        }
        
        ASTNode::NonTerminal(name) => {
            code.push_str(&format!("        self.parse_{}()", name));
        }
        
        ASTNode::Sequence(elements) => {
            code.push_str("        let mut result = String::new();\n");
            for (i, element) in elements.iter().enumerate() {
                match element {
                    ASTNode::Terminal(value) => {
                        let escaped_value = value.replace('"', "\\\"");
                        code.push_str(&format!(r#"        self.match_string("{}")?;
        result.push_str("{}");
"#, escaped_value, escaped_value));
                    }
                    ASTNode::NonTerminal(name) => {
                        code.push_str(&format!("        let part_{} = self.parse_{}()?;\n", i, name));
                        code.push_str(&format!("        result.push_str(&part_{});\n", i));
                    }
                    _ => {
                        code.push_str(&format!("        // TODO: Handle complex element type\n"));
                    }
                }
            }
            code.push_str("        Ok(result)\n");
        }
        
        ASTNode::Choice(alternatives) => {
            code.push_str("        // Try alternatives in order\n");
            for (i, alt) in alternatives.iter().enumerate() {
                if i > 0 {
                    code.push_str("        \n        // Try next alternative\n");
                    code.push_str("        self.position = start_pos; // Reset position\n");
                }
                
                code.push_str(&format!("        if let Ok(result) = (|| -> ParseResult<String> {{\n"));
                
                match alt {
                    ASTNode::Terminal(value) => {
                        let escaped_value = value.replace('"', "\\\"");
                        code.push_str(&format!(r#"            self.match_string("{}")?;
            Ok("{}".to_string())
"#, escaped_value, escaped_value));
                    }
                    ASTNode::NonTerminal(name) => {
                        code.push_str(&format!("            self.parse_{}()", name));
                    }
                    _ => {
                        code.push_str("            // TODO: Handle complex alternative\n");
                        code.push_str("            Ok(String::new())\n");
                    }
                }
                
                code.push_str("        })() {\n");
                code.push_str("            return Ok(result);\n");
                code.push_str("        }\n");
            }
            
            code.push_str(&format!(r#"        
        Err(ParseError {{
            message: "No valid alternative found for {}".to_string(),
            position: start_pos,
            expected: vec!["valid {} alternative".to_string()],
        }})
"#, rule_name, rule_name));
        }
        
        ASTNode::Quantified { symbol, quantifier } => {
            code.push_str("        let mut result = String::new();\n");
            code.push_str("        let mut count = 0;\n");
            
            match quantifier {
                Quantifier::ZeroOrMore => {
                    code.push_str("        // Zero or more (*)\n");
                    code.push_str("        while !self.is_at_end() {\n");
                    code.push_str("            let checkpoint = self.position;\n");
                    // Generate code for the symbol
                    code.push_str("            if let Ok(part) = (|| -> ParseResult<String> {\n");
                    code.push_str(&generate_symbol_parse_code(symbol, 4)?);
                    code.push_str("            })() {\n");
                    code.push_str("                result.push_str(&part);\n");
                    code.push_str("                count += 1;\n");
                    code.push_str("            } else {\n");
                    code.push_str("                self.position = checkpoint;\n");
                    code.push_str("                break;\n");
                    code.push_str("            }\n");
                    code.push_str("        }\n");
                    code.push_str("        Ok(result)\n");
                }
                Quantifier::OneOrMore => {
                    code.push_str("        // One or more (+)\n");
                    code.push_str("        loop {\n");
                    code.push_str("            let checkpoint = self.position;\n");
                    code.push_str("            if let Ok(part) = (|| -> ParseResult<String> {\n");
                    code.push_str(&generate_symbol_parse_code(symbol, 4)?);
                    code.push_str("            })() {\n");
                    code.push_str("                result.push_str(&part);\n");
                    code.push_str("                count += 1;\n");
                    code.push_str("            } else {\n");
                    code.push_str("                self.position = checkpoint;\n");
                    code.push_str("                break;\n");
                    code.push_str("            }\n");
                    code.push_str("        }\n");
                    code.push_str("        if count == 0 {\n");
                    code.push_str(&format!(r#"            return Err(ParseError {{
                message: "Expected at least one occurrence".to_string(),
                position: start_pos,
                expected: vec!["at least one match".to_string()],
            }});
"#));
                    code.push_str("        }\n");
                    code.push_str("        Ok(result)\n");
                }
                Quantifier::Optional => {
                    code.push_str("        // Optional (?)\n");
                    code.push_str("        let checkpoint = self.position;\n");
                    code.push_str("        if let Ok(part) = (|| -> ParseResult<String> {\n");
                    code.push_str(&generate_symbol_parse_code(symbol, 3)?);
                    code.push_str("        })() {\n");
                    code.push_str("            result.push_str(&part);\n");
                    code.push_str("        } else {\n");
                    code.push_str("            self.position = checkpoint;\n");
                    code.push_str("        }\n");
                    code.push_str("        Ok(result)\n");
                }
            }
        }
        
        ASTNode::Group(inner) => {
            code.push_str("        // Group\n");
            code.push_str(&generate_symbol_parse_code(inner, 2)?);
        }
        
        ASTNode::WithAnnotation { node, .. } => {
            // For now, just generate code for the underlying node
            // The annotation handling will be added later
            code.push_str(&generate_parse_function(rule_name, node)?);
        }
    }
    
    code.push_str("    }\n");
    Ok(code)
}

/// Generate parsing code for a symbol with proper indentation
fn generate_symbol_parse_code(symbol: &ASTNode, indent_level: usize) -> Result<String, Box<dyn std::error::Error>> {
    let indent = "    ".repeat(indent_level);
    
    match symbol {
        ASTNode::Terminal(value) => {
            let escaped_value = value.replace('"', "\\\"");
            Ok(format!("{}self.match_string(\"{}\")?;\n{}Ok(\"{}\".to_string())\n", 
                      indent, escaped_value, indent, escaped_value))
        }
        ASTNode::NonTerminal(name) => {
            Ok(format!("{}self.parse_{}()\n", indent, name))
        }
        _ => {
            Ok(format!("{}// TODO: Handle complex symbol\n{}Ok(String::new())\n", indent, indent))
        }
    }
}

/// Extract return annotation from token sequence
fn extract_return_annotation(tokens: Vec<Token>) -> Result<(Vec<Token>, Option<ReturnAnnotation>), Box<dyn std::error::Error>> {
    // Look for return annotation pattern: -> annotation
    let mut clean_tokens = Vec::new();
    let mut annotation = None;
    let mut i = 0;
    
    while i < tokens.len() {
        if tokens[i].token_type == "operator" && tokens[i].value == "->" {
            // Found return annotation, parse remaining tokens as annotation
            let annotation_tokens: Vec<Token> = tokens[(i+1)..].to_vec();
            annotation = Some(parse_return_annotation_tokens(annotation_tokens)?);
            break;
        } else {
            clean_tokens.push(tokens[i].clone());
            i += 1;
        }
    }
    
    Ok((clean_tokens, annotation))
}

/// Parse return annotation tokens into structured annotation
fn parse_return_annotation_tokens(tokens: Vec<Token>) -> Result<ReturnAnnotation, Box<dyn std::error::Error>> {
    if tokens.is_empty() {
        return Err("Empty return annotation".into());
    }
    
    // Simple parser for basic return annotation patterns
    let token_string = tokens.iter().map(|t| t.value.as_str()).collect::<Vec<_>>().join(" ");
    
    // Handle scalar references: $1, $2, etc.
    if let Ok(regex) = Regex::new(r"^\$([0-9]+)$") {
        if let Some(captures) = regex.captures(&token_string) {
            if let Ok(index) = captures[1].parse::<usize>() {
                return Ok(ReturnAnnotation::ScalarRef { index });
            }
        }
    }
    
    // Handle simple array patterns: [$1], [$1*], [$1, $2]
    if token_string.starts_with('[') && token_string.ends_with(']') {
        let inner = &token_string[1..token_string.len()-1];
        if inner.contains(',') {
            // Multiple elements
            let elements = inner.split(',').map(|s| s.trim()).collect::<Vec<_>>();
            let mut contents = Vec::new();
            for element in elements {
                if let Ok(regex) = Regex::new(r"^\$([0-9]+)\*?$") {
                    if let Some(captures) = regex.captures(element) {
                        if let Ok(index) = captures[1].parse::<usize>() {
                            let annotation = if element.ends_with('*') {
                                ReturnAnnotation::Quantified(Box::new(ReturnAnnotation::ScalarRef { index }))
                            } else {
                                ReturnAnnotation::ScalarRef { index }
                            };
                            contents.push(annotation);
                        }
                    } else {
                        contents.push(ReturnAnnotation::Literal(element.to_string()));
                    }
                }
            }
            return Ok(ReturnAnnotation::ArrayExpr { contents });
        } else {
            // Single element array
            if let Ok(regex) = Regex::new(r"^\$([0-9]+)\*?$") {
                if let Some(captures) = regex.captures(inner) {
                    if let Ok(index) = captures[1].parse::<usize>() {
                        let annotation = if inner.ends_with('*') {
                            ReturnAnnotation::Quantified(Box::new(ReturnAnnotation::ScalarRef { index }))
                        } else {
                            ReturnAnnotation::ScalarRef { index }
                        };
                        return Ok(ReturnAnnotation::ArrayExpr { contents: vec![annotation] });
                    }
                }
            }
        }
    }
    
    // Handle simple object patterns: {key: $1}
    if token_string.starts_with('{') && token_string.ends_with('}') {
        let inner = &token_string[1..token_string.len()-1];
        if let Some(colon_pos) = inner.find(':') {
            let key = inner[..colon_pos].trim().to_string();
            let value_str = inner[colon_pos+1..].trim();
            
            if let Ok(regex) = Regex::new(r"^\$([0-9]+)$") {
                if let Some(captures) = regex.captures(value_str) {
                    if let Ok(index) = captures[1].parse::<usize>() {
                        return Ok(ReturnAnnotation::ObjectExpr { 
                            contents: vec![(key, ReturnAnnotation::ScalarRef { index })] 
                        });
                    }
                }
            }
        }
    }
    
    // Fallback to literal
    Ok(ReturnAnnotation::Literal(token_string))
}

/// Apply left recursion elimination using Aho-Sethi-Ullman algorithm
fn eliminate_left_recursion(
    grammar: HashMap<String, ASTNode>,
    options: &Options
) -> Result<HashMap<String, ASTNode>, Box<dyn std::error::Error>> {
    
    if !options.quiet {
        eprintln!("🔥 DEPLOYING LEFT-RECURSION ELIMINATOR!");
        eprintln!("📚 Based on Aho-Sethi-Ullman Algorithm 4.19");
    }
    
    // Convert AST nodes to simple production format
    let mut simple_grammar = HashMap::new();
    let mut rule_order: Vec<String> = grammar.keys().cloned().collect();
    rule_order.sort();
    
    for (rule_name, ast_node) in &grammar {
        simple_grammar.insert(rule_name.clone(), ast_node_to_productions(ast_node)?); 
    }
    
    // Apply the standard algorithm
    for i in 0..rule_order.len() {
        let ai = rule_order[i].clone();
        
        if !options.quiet {
            eprintln!("  Processing rule {} ({}/{})", ai, i+1, rule_order.len());
        }
        
        // Substitute earlier rules
        for j in 0..i {
            let aj = rule_order[j].clone();
            
            if could_create_indirect_left_recursion(&simple_grammar, &ai, &aj) {
                substitute_rule(&mut simple_grammar, &ai, &aj)?;
            }
        }
        
        // Eliminate immediate left recursion
        eliminate_immediate_left_recursion(&mut simple_grammar, &ai, &mut rule_order)?;
    }
    
    // Convert back to AST format
    let mut result_grammar = HashMap::new();
    for (rule_name, productions) in simple_grammar {
        result_grammar.insert(rule_name, productions_to_ast_node(productions)?);
    }
    
    if !options.quiet {
        eprintln!("💀 LEFT-RECURSION ELIMINATION COMPLETE!");
    }
    
    Ok(result_grammar)
}

/// Convert AST node to list of productions
fn ast_node_to_productions(node: &ASTNode) -> Result<Vec<Vec<String>>, Box<dyn std::error::Error>> {
    match node {
        ASTNode::Choice(alternatives) => {
            let mut productions = Vec::new();
            for alt in alternatives {
                productions.extend(ast_node_to_productions(alt)?);
            }
            Ok(productions)
        }
        ASTNode::Sequence(elements) => {
            let mut production = Vec::new();
            for element in elements {
                match element {
                    ASTNode::Terminal(value) => production.push(format!("TERMINAL:{}", value)),
                    ASTNode::NonTerminal(name) => production.push(name.clone()),
                    _ => production.push(format!("COMPLEX:{:?}", element)),
                }
            }
            Ok(vec![production])
        }
        ASTNode::Terminal(value) => {
            Ok(vec![vec![format!("TERMINAL:{}", value)]])
        }
        ASTNode::NonTerminal(name) => {
            Ok(vec![vec![name.clone()]])
        }
        ASTNode::WithAnnotation { node, .. } => {
            // Process the underlying node, annotations will be handled separately
            ast_node_to_productions(node)
        }
        _ => Ok(vec![vec![format!("COMPLEX:{:?}", node)]])
    }
}

/// Convert productions back to AST node
fn productions_to_ast_node(productions: Vec<Vec<String>>) -> Result<ASTNode, Box<dyn std::error::Error>> {
    if productions.is_empty() {
        return Ok(ASTNode::Terminal("epsilon".to_string()));
    }
    
    if productions.len() == 1 {
        let production = &productions[0];
        if production.len() == 1 {
            let symbol = &production[0];
            if symbol.starts_with("TERMINAL:") {
                Ok(ASTNode::Terminal(symbol[9..].to_string()))
            } else {
                Ok(ASTNode::NonTerminal(symbol.clone()))
            }
        } else {
            let mut elements = Vec::new();
            for symbol in production {
                if symbol.starts_with("TERMINAL:") {
                    elements.push(ASTNode::Terminal(symbol[9..].to_string()));
                } else {
                    elements.push(ASTNode::NonTerminal(symbol.clone()));
                }
            }
            Ok(ASTNode::Sequence(elements))
        }
    } else {
        let mut alternatives = Vec::new();
        for production in productions {
            alternatives.push(productions_to_ast_node(vec![production])?);
        }
        Ok(ASTNode::Choice(alternatives))
    }
}

/// Check if substitution could create indirect left recursion
fn could_create_indirect_left_recursion(
    grammar: &HashMap<String, Vec<Vec<String>>>,
    current_rule: &str,
    referenced_rule: &str
) -> bool {
    if let Some(productions) = grammar.get(referenced_rule) {
        for production in productions {
            if !production.is_empty() && production[0] == current_rule {
                return true;
            }
        }
    }
    false
}

/// Substitute rule in grammar
fn substitute_rule(
    grammar: &mut HashMap<String, Vec<Vec<String>>>,
    target_rule: &str,
    substitute_rule: &str
) -> Result<(), Box<dyn std::error::Error>> {
    let target_productions = grammar.get(target_rule).cloned().unwrap_or_default();
    let substitute_productions = grammar.get(substitute_rule).cloned().unwrap_or_default();
    
    let mut new_productions = Vec::new();
    
    for production in target_productions {
        if !production.is_empty() && production[0] == substitute_rule {
            // Substitute this production
            let gamma = &production[1..]; // Rest after the substituted rule
            
            for sub_production in &substitute_productions {
                if sub_production.len() == 1 && sub_production[0] == "ε" {
                    // Epsilon production
                    new_productions.push(gamma.to_vec());
                } else {
                    // Normal substitution
                    let mut new_production = sub_production.clone();
                    new_production.extend_from_slice(gamma);
                    new_productions.push(new_production);
                }
            }
        } else {
            // Keep as-is
            new_productions.push(production);
        }
    }
    
    grammar.insert(target_rule.to_string(), new_productions);
    Ok(())
}

/// Eliminate immediate left recursion from a rule
fn eliminate_immediate_left_recursion(
    grammar: &mut HashMap<String, Vec<Vec<String>>>,
    rule: &str,
    rule_order: &mut Vec<String>
) -> Result<(), Box<dyn std::error::Error>> {
    let productions = grammar.get(rule).cloned().unwrap_or_default();
    
    let mut left_recursive = Vec::new();
    let mut non_left_recursive = Vec::new();
    
    for production in productions {
        if !production.is_empty() && production[0] == rule {
            left_recursive.push(production);
        } else {
            non_left_recursive.push(production);
        }
    }
    
    if !left_recursive.is_empty() {
        let prime_rule = format!("{}_prime", rule);
        
        // Create new main productions: A → β A'
        let mut new_main_productions = Vec::new();
        if non_left_recursive.is_empty() {
            new_main_productions.push(vec![prime_rule.clone()]);
        } else {
            for beta in non_left_recursive {
                let mut production = beta;
                production.push(prime_rule.clone());
                new_main_productions.push(production);
            }
        }
        
        // Create prime productions: A' → α A' | ε
        let mut prime_productions = Vec::new();
        for left_prod in left_recursive {
            let mut alpha = left_prod[1..].to_vec(); // Remove the left-recursive symbol
            alpha.push(prime_rule.clone());
            prime_productions.push(alpha);
        }
        prime_productions.push(vec!["ε".to_string()]);
        
        // Update grammar
        grammar.insert(rule.to_string(), new_main_productions);
        grammar.insert(prime_rule.clone(), prime_productions);
        
        // Add prime rule to order
        if !rule_order.contains(&prime_rule) {
            rule_order.push(prime_rule);
        }
    }
    
    Ok(())
}

/// Derive module name from grammar name
fn derive_module_name(grammar_name: &str) -> String {
    // Clean up grammar name to valid Rust module name
    grammar_name
        .chars()
        .map(|c| if c.is_alphanumeric() || c == '_' { c } else { '_' })
        .collect::<String>()
        .to_lowercase()
}
