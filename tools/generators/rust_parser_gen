/// Main generator logic
fn run_generator(options: Options) -> Result<(), Box<dyn std::error::Error>> {
    // Read JSON input
    let json_content = if let Some(input_file) = &options.input_file {
        if !options.quiet {
            eprintln!("📄 Reading JSON from: {}", input_file);
        }
        fs::read_to_string(input_file)?
    } else {
        if !options.quiet {
            eprintln!("📄 Reading JSON from STDIN");
        }
        let mut buffer = String::new();
        io::stdin().read_to_string(&mut buffer)?;
        buffer
    };
    
    // Parse JSON
    let json_data: Value = serde_json::from_str(&json_content)?;
    
    // Validate JSON structure
    let grammar_name = json_data["grammar_name"]
        .as_str()
        .ok_or("Invalid JSON: missing grammar_name")?;
        
    let raw_ast = json_data["raw_ast"]
        .as_array()
        .ok_or("Invalid JSON: missing or invalid raw_ast")?;
        
    if !options.quiet {
        eprintln!("🦀 Generating Rust parser for grammar: {}", grammar_name);
    }
    
    // Run the transformation pipeline
    let parser_result = generate_rust_parser_from_json(raw_ast, grammar_name, &options)?;
    
    // Determine module name
    let module_name = options.module_name
        .unwrap_or_else(|| derive_module_name(grammar_name));
    
    // Output results
    if let Some(output_file) = &options.output_file {
        let rs_file = if output_file.ends_with(".rs") {
            output_file.clone()
        } else {
            format!("{}.rs", output_file)
        };
        
        let rust_code = parser_result.replace("MODULE_NAME_PLACEHOLDER", &module_name);
        fs::write(&rs_file, rust_code)?;
        
        if !options.quiet {
            eprintln!("✅ Rust parser written to: {}", rs_file);
        }
    } else {
        let rust_code = parser_result.replace("MODULE_NAME_PLACEHOLDER", &module_name);
        print!("{}", rust_code);
    }
    
    Ok(())
}

/// Generate Rust parser from JSON raw AST
fn generate_rust_parser_from_json(
    raw_ast: &[Value], 
    grammar_name: &str, 
    options: &Options
) -> Result<String, Box<dyn std::error::Error>> {
    
    if !options.quiet {
        eprintln!("\n=== Running Enhanced 6-Step Transformation Pipeline ===");
    }
    
    // First, normalize raw AST to handle both Format 1 and Format 2
    let normalized_rules = normalize_raw_ast(raw_ast, options)?;
    
    // Parse normalized AST into token structures and process with 5-step pipeline
    let mut grammar_rules = HashMap::new();
    
    for (rule_name, combined_tokens) in normalized_rules {
        // Run the 5-step transformation pipeline
        if !options.quiet {
            eprintln!("Processing rule: {} ({} tokens)", rule_name, combined_tokens.len());
        }
        
        let transformed_rule = transform_rule(&rule_name, combined_tokens, options)?;
        grammar_rules.insert(rule_name, transformed_rule);
    }
    
    // Step 6a: Apply left recursion elimination
    if !options.quiet {
        eprintln!("Step 6a: Applying left recursion elimination...");
    }
    let grammar_rules = eliminate_left_recursion(grammar_rules, options)?;
    
    // Step 6b: Generate Rust code with return annotations
    if !options.quiet {
        eprintln!("Step 6b: Generating Rust code with semantic actions...");
    }
    
    let rust_code = generate_rust_code(&grammar_rules, grammar_name)?;
    Ok(rust_code)
}

/// Normalize raw AST to handle both Format 1 and Format 2
fn normalize_raw_ast(
    raw_ast: &[Value],
    options: &Options
) -> Result<HashMap<String, Vec<Token>>, Box<dyn std::error::Error>> {
    
    // Check if we have Format 2 (multiple rule arrays)
    let is_format2 = raw_ast.iter().all(|rule| {
        rule.as_array()
            .map(|arr| arr.len() >= 1 && arr[0].as_array().is_some())
            .unwrap_or(false)
    });
    
    if is_format2 {
        // Format 2: Group alternatives by rule name
        if !options.quiet {
            eprintln!("Detected Format 2 (multiple rule definitions) - normalizing...");
        }
        
        let mut rule_definitions: HashMap<String, Vec<Vec<Token>>> = HashMap::new();
        
        for rule_array in raw_ast {
            let rule_tokens = rule_array.as_array()
                .ok_or("Invalid rule format: expected array")?;
                
            if rule_tokens.is_empty() {
                continue;
            }
            
            // First token should be the rule name
            let rule_name = extract_rule_name(&rule_tokens[0])?;
            
            // Rest are the rule definition tokens
            let definition_tokens: Vec<Token> = rule_tokens[1..]
                .iter()
                .map(|v| parse_token(v))
                .collect::<Result<Vec<_>, _>>()?;
                
            // Group by rule name
            rule_definitions.entry(rule_name).or_insert_with(Vec::new)
                .push(definition_tokens);
        }
        
        // Convert to Format 1: OR-separated token streams
        let mut normalized = HashMap::new();
        for (rule_name, alternatives) in rule_definitions {
            let mut combined_tokens = Vec::new();
            
            for (i, alt_tokens) in alternatives.into_iter().enumerate() {
                if i > 0 {
                    combined_tokens.push(Token {
                        token_type: "operator".to_string(),
                        value: "|".to_string(),
                    });
                }
                combined_tokens.extend(alt_tokens);
            }
            
            normalized.insert(rule_name, combined_tokens);
        }
        
        Ok(normalized)
    } else {
        // Format 1: Already normalized (single rules with OR operators)
        if !options.quiet {
            eprintln!("Detected Format 1 (OR-separated tokens) - processing directly...");
        }
        
        let mut normalized = HashMap::new();
        
        for rule_array in raw_ast {
            let rule_tokens = rule_array.as_array()
                .ok_or("Invalid rule format: expected array")?;
                
            if rule_tokens.is_empty() {
                continue;
            }
            
            // First token should be the rule name
            let rule_name = extract_rule_name(&rule_tokens[0])?;
            
            // Rest are the rule definition tokens
            let definition_tokens: Vec<Token> = rule_tokens[1..]
                .iter()
                .map(|v| parse_token(v))
                .collect::<Result<Vec<_>, _>>()?;
                
            normalized.insert(rule_name, definition_tokens);
        }
        
        Ok(normalized)
    }
}

/// Token representation
#[derive(Debug, Clone)]
struct Token {
    token_type: String,
    value: String,
}

/// Intermediate structures for pipeline steps
#[derive(Debug, Clone)]
enum AlternativeType {
    Single(Token),
    Sequence(Vec<Token>),
}

/// Represents an alternative after Step 3
#[derive(Debug, Clone)]
struct Alternative {
    alt_type: String, // "single" or "sequence"
    content: Vec<Token>,
}

/// Parse a JSON value into a Token
fn parse_token(value: &Value) -> Result<Token, Box<dyn std::error::Error>> {
    let array = value.as_array()
        .ok_or("Token must be array")?;
        
    if array.len() != 2 {
        return Err("Token array must have exactly 2 elements".into());
    }
    
    let token_type = array[0].as_str()
        .ok_or("Token type must be string")?
        .to_string();
        
    let token_value = array[1].as_str()
        .ok_or("Token value must be string")?
        .to_string();
        
    Ok(Token {
        token_type,
        value: token_value,
    })
}

/// Extract rule name from rule token
fn extract_rule_name(token: &Value) -> Result<String, Box<dyn std::error::Error>> {
    let array = token.as_array()
        .ok_or("Rule token must be array")?;
        
    if array.len() != 2 || array[0].as_str() != Some("rule") {
        return Err("Invalid rule token format".into());
    }
    
    Ok(array[1].as_str()
        .ok_or("Rule name must be string")?
        .to_string())
}

/// Return annotation AST for structured semantic actions
#[derive(Debug, Clone)]
enum ReturnAnnotation {
    ScalarRef { index: usize },
    ArrayExpr { contents: Vec<ReturnAnnotation> },
    ObjectExpr { contents: Vec<(String, ReturnAnnotation)> },
    Literal(String),
    DotAccess { base: Box<ReturnAnnotation>, field: String },
    Quantified(Box<ReturnAnnotation>),
}

/// Grammar production for left recursion elimination
#[derive(Debug, Clone)]
struct Production {
    symbols: Vec<String>,
    annotation: Option<ReturnAnnotation>,
}

/// Grammar rule with alternatives and annotations
#[derive(Debug, Clone)]
struct GrammarRule {
    name: String,
    productions: Vec<Production>,
}

/// AST Node types for the transformed tree
#[derive(Debug, Clone)]
enum ASTNode {
    Terminal(String),
    NonTerminal(String),
    Sequence(Vec<ASTNode>),
    Choice(Vec<ASTNode>), 
    Quantified {
        symbol: Box<ASTNode>,
        quantifier: Quantifier,
    },
    Group(Box<ASTNode>),
    WithAnnotation {
        node: Box<ASTNode>,
        annotation: ReturnAnnotation,
    },
}

#[derive(Debug, Clone)]
enum Quantifier {
    Optional,    // ?
    ZeroOrMore, // *
    OneOrMore,  // +
}

/// Transform a rule using the 5-step pipeline with full Step 6 implementation
fn transform_rule(
    rule_name: &str,
    tokens: Vec<Token>,
    options: &Options
) -> Result<ASTNode, Box<dyn std::error::Error>> {
    
    // Parse return annotations from tokens if present
    let (clean_tokens, return_annotation) = extract_return_annotation(tokens)?;
    
    // Step 2: Group by OR operators
    if !options.quiet {
        eprintln!("  Step 2: Grouping by OR operators...");
    }
    let alternatives = step2_group_by_or(clean_tokens)?;
    
    // Step 2.5: Handle parentheses  
    if !options.quiet {
        eprintln!("  Step 2.5: Handling parentheses...");
    }
    let alternatives = step2_5_handle_parentheses(alternatives)?;
    
    // Step 3: Parse sequences
    if !options.quiet {
        eprintln!("  Step 3: Parsing sequences...");
    }
    let alternatives = step3_parse_sequences(alternatives)?;
    
    // Step 4: Handle quantifiers
    if !options.quiet {
        eprintln!("  Step 4: Handling quantifiers...");
    }
    let alternatives = step4_handle_quantifiers(alternatives)?;
    
    // Step 5: Build tree structure
    if !options.quiet {
        eprintln!("  Step 5: Building tree structure...");
    }
    let mut tree = step5_build_tree_structure(rule_name, alternatives)?;
    
    // Attach return annotation if present
    if let Some(annotation) = return_annotation {
        tree = ASTNode::WithAnnotation {
            node: Box::new(tree),
            annotation,
        };
    }
    
    Ok(tree)
}

/// Step 2: Group by OR operators
fn step2_group_by_or(tokens: Vec<Token>) -> Result<Vec<Vec<Token>>, Box<dyn std::error::Error>> {
    let mut alternatives = Vec::new();
    let mut current_alt = Vec::new();
    
    for token in tokens {
        if token.token_type == "operator" && token.value == "|" {
            if !current_alt.is_empty() {
                alternatives.push(current_alt);
                current_alt = Vec::new();
            }
        } else {
            current_alt.push(token);
        }
    }
    
    // Add final alternative
    if !current_alt.is_empty() {
        alternatives.push(current_alt);
    }
    
    // Filter out empty alternatives
    let alternatives: Vec<_> = alternatives.into_iter()
        .filter(|alt| !alt.is_empty())
        .collect();
        
    if alternatives.is_empty() {
        return Err("No valid alternatives found".into());
    }
    
    Ok(alternatives)
}

/// Step 2.5: Handle parentheses
fn step2_5_handle_parentheses(alternatives: Vec<Vec<Token>>) -> Result<Vec<Vec<Token>>, Box<dyn std::error::Error>> {
    let mut result = Vec::new();
    
    for alt in alternatives {
        let processed = handle_parentheses_in_sequence(alt)?;
        result.push(processed);
    }
    
    Ok(result)
}

/// Process parentheses within a token sequence
fn handle_parentheses_in_sequence(tokens: Vec<Token>) -> Result<Vec<Token>, Box<dyn std::error::Error>> {
    let mut result = Vec::new();
    let mut i = 0;
    
    while i < tokens.len() {
        let token = &tokens[i];
        
        if token.token_type == "operator" && token.value == "(" {
            // Find matching closing parenthesis and extract group
            let (_group_tokens, end_pos) = extract_parentheses_group(&tokens, i)?;
            
            // Create a group token
            let group_token = Token {
                token_type: "group".to_string(),
                value: format!("group_{}", result.len()), // Unique identifier
            };
            
            result.push(group_token);
            i = end_pos + 1;
        } else {
            result.push(token.clone());
            i += 1;
        }
    }
    
    Ok(result)
}

/// Extract tokens within parentheses
fn extract_parentheses_group(tokens: &[Token], start_pos: usize) -> Result<(Vec<Token>, usize), Box<dyn std::error::Error>> {
    let mut depth = 0;
    let mut group = Vec::new();
    
    for i in start_pos..tokens.len() {
        let token = &tokens[i];
        
        if token.token_type == "operator" && token.value == "(" {
            if depth > 0 {
                group.push(token.clone());
            }
            depth += 1;
        } else if token.token_type == "operator" && token.value == ")" {
            depth -= 1;
            if depth == 0 {
                return Ok((group, i));
            } else {
                group.push(token.clone());
            }
        } else if depth > 0 {
            group.push(token.clone());
        }
    }
    
    Err("Unmatched parentheses".into())
}

/// Step 3: Parse sequences
fn step3_parse_sequences(alternatives: Vec<Vec<Token>>) -> Result<Vec<Alternative>, Box<dyn std::error::Error>> {
    let mut result = Vec::new();
    
    for alt in alternatives {
        // Filter out whitespace and comments
        let filtered: Vec<Token> = alt.into_iter()
            .filter(|t| t.token_type != "whitespace" && t.token_type != "comment")
            .collect();
            
        if filtered.is_empty() {
            continue; // Skip empty alternatives
        } else if filtered.len() == 1 {
            result.push(Alternative {
                alt_type: "single".to_string(),
                content: filtered,
            });
        } else {
            result.push(Alternative {
                alt_type: "sequence".to_string(),
                content: filtered,
            });
        }
    }
    
    Ok(result)
}

/// Step 4: Handle quantifiers
fn step4_handle_quantifiers(alternatives: Vec<Alternative>) -> Result<Vec<Alternative>, Box<dyn std::error::Error>> {
    let mut result = Vec::new();
    
    for alt in alternatives {
        let processed_content = if alt.alt_type == "sequence" {
            process_quantifiers_in_sequence(alt.content)?
        } else if alt.alt_type == "single" {
            // For single items, check if next token would be a quantifier
            alt.content // Single items don't have following quantifiers in this step
        } else {
            alt.content
        };
        
        result.push(Alternative {
            alt_type: alt.alt_type,
            content: processed_content,
        });
    }
    
    Ok(result)
}

/// Process quantifiers within a sequence
fn process_quantifiers_in_sequence(sequence: Vec<Token>) -> Result<Vec<Token>, Box<dyn std::error::Error>> {
    let mut result = Vec::new();
    let mut i = 0;
    
    while i < sequence.len() {
        let token = sequence[i].clone();
        
        // Look ahead for quantifier
        if i + 1 < sequence.len() && sequence[i + 1].token_type == "quantifier" {
            let quantifier = &sequence[i + 1];
            
            // Create quantified token
            let quantified_token = Token {
                token_type: "quantified".to_string(),
                value: format!("{}:{}", token.value, quantifier.value),
            };
            
            result.push(quantified_token);
            i += 2; // Skip both token and quantifier
        } else {
            result.push(token);
            i += 1;
        }
    }
    
    Ok(result)
}

/// Step 5: Build tree structure
fn step5_build_tree_structure(_rule_name: &str, alternatives: Vec<Alternative>) -> Result<ASTNode, Box<dyn std::error::Error>> {
    if alternatives.len() == 1 {
        // Single alternative - no choice needed
        build_alternative_tree_from_alt(&alternatives[0])
    } else {
        // Multiple alternatives - create choice node
        let mut choice_branches = Vec::new();
        for alt in alternatives {
            choice_branches.push(build_alternative_tree_from_alt(&alt)?);
        }
        
        Ok(ASTNode::Choice(choice_branches))
    }
}

/// Build AST tree for a single alternative from Alternative struct
fn build_alternative_tree_from_alt(alternative: &Alternative) -> Result<ASTNode, Box<dyn std::error::Error>> {
    if alternative.alt_type == "single" {
        // Single symbol
        if alternative.content.len() != 1 {
            return Err("Single alternative must have exactly one token".into());
        }
        build_symbol_tree(&alternative.content[0])
    } else if alternative.alt_type == "sequence" {
        // Sequence of symbols
        let mut elements = Vec::new();
        for token in &alternative.content {
            elements.push(build_symbol_tree(token)?);
        }
        Ok(ASTNode::Sequence(elements))
    } else {
        Err(format!("Unknown alternative type: {}", alternative.alt_type).into())
    }
}

/// Build AST tree for a single alternative
fn build_alternative_tree(alternative: &[Token]) -> Result<ASTNode, Box<dyn std::error::Error>> {
    if alternative.len() == 1 {
        // Single symbol
        build_symbol_tree(&alternative[0])
    } else {
        // Sequence of symbols
        let mut elements = Vec::new();
        for token in alternative {
            elements.push(build_symbol_tree(token)?);
        }
        Ok(ASTNode::Sequence(elements))
    }
}

/// Build AST tree for a single symbol
fn build_symbol_tree(token: &Token) -> Result<ASTNode, Box<dyn std::error::Error>> {
    match token.token_type.as_str() {
        "identifier" => Ok(ASTNode::NonTerminal(token.value.clone())),
        "quoted_string" => Ok(ASTNode::Terminal(token.value.clone())),
        "rule_reference" => Ok(ASTNode::NonTerminal(token.value.clone())),
        "regex" => Ok(ASTNode::Terminal(token.value.clone())),
        "quantified" => {
            // Parse quantified token: "symbol:quantifier"
            let parts: Vec<&str> = token.value.split(':').collect();
            if parts.len() != 2 {
                return Err("Invalid quantified token format".into());
            }
            
            let symbol = Token {
                token_type: "identifier".to_string(), // Assume identifier for now
                value: parts[0].to_string(),
            };
            
            let quantifier = match parts[1] {
                "?" => Quantifier::Optional,
                "*" => Quantifier::ZeroOrMore,
                "+" => Quantifier::OneOrMore,
                _ => return Err(format!("Unknown quantifier: {}", parts[1]).into()),
            };
            
            Ok(ASTNode::Quantified {
                symbol: Box::new(build_symbol_tree(&symbol)?),
                quantifier,
            })
        }
        "group" => {
            // For now, treat groups as non-terminals
            // In a more sophisticated implementation, we would process the group contents
            Ok(ASTNode::NonTerminal(format!("group_{}", token.value)))
        }
        "return_scalar" | "return_array" | "return_object" => {
            // Return annotations - treat as terminals for now, will be processed later
            Ok(ASTNode::Terminal(token.value.clone()))
        }
        "operator" => {
            // Operators as terminals - flexible handling
            Ok(ASTNode::Terminal(token.value.clone()))
        }
        "group_open" | "group_close" => {
            // Group markers as terminals
            Ok(ASTNode::Terminal(token.value.clone()))
        }
        "number" => {
            // Numbers as terminals
            Ok(ASTNode::Terminal(token.value.clone()))
        }
        _ => {
            eprintln!("Warning: Unknown token type '{}' - treating as terminal", token.token_type);
            Ok(ASTNode::Terminal(token.value.clone()))
        }
    }
}

/// Generate Rust code from the transformed grammar tree
fn generate_rust_code(grammar: &HashMap<String, ASTNode>, grammar_name: &str) -> Result<String, Box<dyn std::error::Error>> {
    let mut code = String::new();
    
    // Module header
    code.push_str(&format!(r#"//! {} Parser
//! 
//! Generated from EBNF grammar using rust_parser_gen
//! This parser implements a recursive descent parser with comprehensive error handling.

use std::fmt;

/// MODULE_NAME_PLACEHOLDER - Generated parser module
pub mod MODULE_NAME_PLACEHOLDER {{

/// Parse result type
pub type ParseResult<T> = Result<T, ParseError>;

/// Parse error with position information
#[derive(Debug, Clone)]
pub struct ParseError {{
    pub message: String,
    pub position: usize,
    pub expected: Vec<String>,
}}

impl fmt::Display for ParseError {{
    fn fmt(&self, f: &mut fmt::Formatter<'_>) -> fmt::Result {{
        write!(f, "Parse error at position {{}}: {{}}", self.position, self.message)
    }}
}}

