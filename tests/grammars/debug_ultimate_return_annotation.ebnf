# DEBUG VERSION - ULTIMATE RETURN ANNOTATION GRAMMAR
# Analysis focus: Why multi-element arrays fail

# Main entry point
return_annotation := '->' /\s*/ return_expression

# CORE: Recursive return expressions
return_expression := nested_array | nested_object | grouped_quantified_array | simple_nested_object | multi_property_object | quantified_array | simple_array | simple_object | ultimate_dot_notation | scalar_ref | literal

# ===================================================================
# ARRAY PARSING ANALYSIS - THE CORE ISSUE
# ===================================================================

# RECURSIVE ARRAYS - These SHOULD handle multi-element arrays
# Line 14-15: This is the key rule that should parse [$1, $2]
nested_array := '[' /\s*/ array_contents? /\s*/ ']' quantifier? -> {type: "array", contents: $3, quantified: $6}
array_contents := return_expression (',' /\s*/ return_expression)* -> [$1, $3*]

# ANALYSIS: array_contents should parse:
# - return_expression = first element (e.g., $1)  
# - (',' /\s*/ return_expression)* = zero or more comma-separated additional elements
# - -> [$1, $3*] = collect first element + array of remaining elements
#
# This SHOULD work for [$1, $2] because:
# 1. '[' matches
# 2. array_contents matches: return_expression($1) + (',' return_expression($2))*
# 3. ']' matches
# 
# WHY DOES IT FAIL? Let's check if return_expression includes scalar_ref...

# OBJECTS - These WORK for multi-property
nested_object := '{' /\s*/ object_contents? /\s*/ '}' quantifier? -> {type: "object", contents: $3, quantified: $6}
object_contents := object_pair (',' /\s*/ object_pair)* -> [$1, $3*]
object_pair := object_key /\s*/ ':' /\s*/ return_expression -> {key: $1, value: $5}

# ANALYSIS: object_contents works because:
# - object_pair handles each key:value pair
# - (',' /\s*/ object_pair)* handles comma separation
# - This is EXACTLY the same pattern as array_contents!

# ===================================================================
# SIMPLE ARRAYS - These work for single elements
# ===================================================================

# QUANTIFIED ARRAYS - These WORK
quantified_array := '[' /\s*/ quantified_element /\s*/ ']' -> {type: "quantified_array", element: $3}
quantified_element := ultimate_dot_notation quantifier -> {scalar: $1, quantifier: $2}
                    | scalar_ref quantifier -> {scalar: $1, quantifier: $2}

# SIMPLE ARRAYS - These work for single elements  
simple_array := '[' /\s*/ array_element /\s*/ ']' -> {type: "array", element: $3}
array_element := ultimate_dot_notation | scalar_ref | literal | nested_array | nested_object

# ===================================================================
# HYPOTHESIS: Parser Priority/Ordering Issue
# ===================================================================
#
# The issue might be in return_expression ordering:
# return_expression := nested_array | nested_object | grouped_quantified_array | simple_nested_object | multi_property_object | quantified_array | simple_array | simple_object | ultimate_dot_notation | scalar_ref | literal
#
# POTENTIAL PROBLEM: 
# - quantified_array comes BEFORE simple_array
# - Parser might try quantified_array first for [$1, $2]
# - quantified_array expects [$1*] or [$1+], not [$1, $2]  
# - Parser fails on quantified_array, then tries simple_array
# - simple_array expects single element, fails on comma
# - Parser never gets to try nested_array!
#
# SOLUTION: nested_array should come FIRST in return_expression

# ===================================================================
# REST OF GRAMMAR (unchanged for debugging)
# ===================================================================

# ULTIMATE DOT NOTATION
ultimate_dot_notation := scalar_ref dot_path -> {type: "ultimate_dot_notation", base: $1, path: $2}
dot_path := accessor+ -> [$1*]
accessor := property_accessor | positional_accessor | array_accessor
property_accessor := '.' identifier -> {type: "property", name: $2}
positional_accessor := '.' positive_number -> {type: "position", index: $2}
array_accessor := '[' array_spec ']' -> {type: "array_access", spec: $2}

# Array specification 
array_spec := 
    | empty_spec -> {type: "whole_array", style: "implicit"}
    | star_spec -> {type: "whole_array", style: "bash"}
    | colon_spec -> {type: "whole_array", style: "python"}
    | single_index -> $1
    | perl_range -> $1
    | python_slice -> $1
    | python_slice_with_step -> $1
    | index_list -> {type: "multi_index", indices: $1}
    | mixed_expression -> {type: "mixed_expression", elements: $1}

empty_spec := /(?=\])/
star_spec := '*'
colon_spec := ':'
single_index := index -> {type: "single_index", value: $1}
perl_range := index '..' index -> {type: "perl_range", start: $1, end: $3}
python_slice := python_slice_start ':' python_slice_end -> {type: "python_slice", start: $1, end: $3}
python_slice_with_step := python_slice_start ':' python_slice_end ':' step -> {type: "python_slice_step", start: $1, end: $3, step: $5}
python_slice_start := index | empty_slice_part
python_slice_end := index | empty_slice_part  
step := index
empty_slice_part := /(?=:)/
index_list := index (',' /\s*/ index)* -> [$1, $3*]
mixed_expression := mixed_element (',' /\s*/ mixed_element)* -> [$1, $3*]
mixed_element := single_index | perl_range | python_slice | python_slice_with_step
index := positive_number | negative_number
positive_number := /(\\d+)/ -> {type: "positive", value: $1}
negative_number := '-' positive_number -> {type: "negative", value: $2}

# LEGACY PATTERNS
grouped_quantified_array := '[' /\s*/ grouped_element_list /\s*/ ']' -> {type: "grouped_quantified_array", groups: $3}
grouped_element_list := grouped_element_item (',' /\s*/ grouped_element_item)* -> [$1, $3*]
                      | grouped_element_item -> [$1]
grouped_element_item := '(' /\s*/ group_content /\s*/ ')' quantifier -> {type: "grouped_quantified", content: $3, quantifier: $6}
                      | element_sequence quantifier -> {type: "sequence_quantified", content: $1, quantifier: $2}
group_content := element_sequence
element_sequence := element_item (/\s+/ element_item)* -> [$1, $3*]
                  | element_item -> [$1]
element_item := identifier | literal

# Simple nested object
simple_nested_object := '{' /\s*/ outer_key /\s*/ ':' /\s*/ inner_object /\s*/ '}' -> {type: "nested_object", key: $3, value: $7}
inner_object := '{' /\s*/ inner_key /\s*/ ':' /\s*/ inner_value /\s*/ '}' -> {type: "inner_object", key: $3, value: $7}
inner_value := nested_array | nested_object | grouped_quantified_array | quantified_array | simple_array | ultimate_dot_notation | scalar_ref | literal

# Multi-property objects
multi_property_object := two_property_object | three_property_object
two_property_object := '{' /\s*/ property ',' /\s*/ property /\s*/ '}' -> {type: "multi_object", prop1: $3, prop2: $6}
three_property_object := '{' /\s*/ property ',' /\s*/ property ',' /\s*/ property /\s*/ '}' -> {type: "multi_object", prop1: $3, prop2: $6, prop3: $9}
property := object_key /\s*/ ':' /\s*/ property_value -> {key: $1, value: $5}
property_value := nested_array | nested_object | grouped_quantified_array | quantified_array | simple_array | ultimate_dot_notation | scalar_ref | literal

# ENHANCED QUANTIFIERS
quantifier := '*' -> "*"
            | '+' -> "+"
            | '?' -> "?"
            | '{' /\s*/ positive_number /\s*/ '}' -> {min: $3, max: $3}
            | '{' /\s*/ positive_number /\s*/ ',' /\s*/ '}' -> {min: $3, max: "inf"}
            | '{' /\s*/ positive_number /\s*/ ',' /\s*/ positive_number /\s*/ '}' -> {min: $3, max: $7}
            | '{' /\s*/ ',' /\s*/ positive_number /\s*/ '}' -> {min: 0, max: $5}

# BASIC ELEMENTS
literal := quoted_string | number
scalar_ref := '$' positive_number -> {type: "scalar_ref", index: $2}
quoted_string := /"([^"]*)"/ -> $1
number := /(\\d+)/ -> $1
identifier := /([a-zA-Z_]\\w*)/ -> $1
object_key := identifier | quoted_string
outer_key := identifier | quoted_string  
inner_key := identifier | quoted_string
object_value := ultimate_dot_notation | scalar_ref | literal | nested_array | nested_object
