{
  "version": 1,
  "grammar": "return_annotation",
  "annotation_count": 16,
  "annotations": [
    {
      "rule": "accessor_base",
      "branch_index": 3,
      "annotation_type": "return_scalar",
      "raw_text": "$2",
      "normalized_text": "$2"
    },
    {
      "rule": "array_access_expression",
      "branch_index": 0,
      "annotation_type": "return_object",
      "raw_text": "{type: \"array_access\", base: $1, index: $3}",
      "normalized_text": "{type: \"array_access\", base: $1, index: $3}"
    },
    {
      "rule": "array_elements",
      "branch_index": 0,
      "annotation_type": "return_array",
      "raw_text": "[$1, $2::2*]",
      "normalized_text": "[$1, $2::2*]"
    },
    {
      "rule": "array_literal",
      "branch_index": 0,
      "annotation_type": "return_object",
      "raw_text": "{type: \"array\", elements: $2}",
      "normalized_text": "{type: \"array\", elements: $2}"
    },
    {
      "rule": "extraction_expression",
      "branch_index": 0,
      "annotation_type": "return_object",
      "raw_text": "{\n    type: \"extraction\",\n    base: $1,\n    target: $3,\n    spread: $4\n}",
      "normalized_text": "{ type: \"extraction\", base: $1, target: $3, spread: $4 }"
    },
    {
      "rule": "object_literal",
      "branch_index": 0,
      "annotation_type": "return_object",
      "raw_text": "{type: \"object\", properties: $2}",
      "normalized_text": "{type: \"object\", properties: $2}"
    },
    {
      "rule": "object_properties",
      "branch_index": 0,
      "annotation_type": "return_array",
      "raw_text": "[$1, $2::2*]",
      "normalized_text": "[$1, $2::2*]"
    },
    {
      "rule": "object_property",
      "branch_index": 0,
      "annotation_type": "return_object",
      "raw_text": "{key: $1, value: $3}",
      "normalized_text": "{key: $1, value: $3}"
    },
    {
      "rule": "parenthesized",
      "branch_index": 0,
      "annotation_type": "return_scalar",
      "raw_text": "$2",
      "normalized_text": "$2"
    },
    {
      "rule": "positional_reference",
      "branch_index": 0,
      "annotation_type": "return_object",
      "raw_text": "{type: \"positional\", index: $2}",
      "normalized_text": "{type: \"positional\", index: $2}"
    },
    {
      "rule": "primary_expression",
      "branch_index": 7,
      "annotation_type": "return_scalar",
      "raw_text": "$2",
      "normalized_text": "$2"
    },
    {
      "rule": "property_access_expression",
      "branch_index": 0,
      "annotation_type": "return_object",
      "raw_text": "{type: \"property_access\", base: $1, property: $3}",
      "normalized_text": "{type: \"property_access\", base: $1, property: $3}"
    },
    {
      "rule": "spread_expression",
      "branch_index": 0,
      "annotation_type": "return_object",
      "raw_text": "{type: \"spread\", base: $1}",
      "normalized_text": "{type: \"spread\", base: $1}"
    },
    {
      "rule": "spread_suffix",
      "branch_index": 0,
      "annotation_type": "return_scalar",
      "raw_text": "\"true\"",
      "normalized_text": "\"true\""
    },
    {
      "rule": "spreadable_expression",
      "branch_index": 4,
      "annotation_type": "return_scalar",
      "raw_text": "$2",
      "normalized_text": "$2"
    },
    {
      "rule": "string_literal",
      "branch_index": 0,
      "annotation_type": "return_object",
      "raw_text": "{type: \"string\", value: $2}",
      "normalized_text": "{type: \"string\", value: $2}"
    }
  ]
}
