{
  "name": "Return Annotations - Round-Trip Complex Tests",
  "description": "Complex round-trip testing for arrays and objects",
  "tests": [
    {
      "name": "simple_array_round_trip",
      "description": "Simple array round-trip",
      "input": "[$1, $2]",
      "expected_round_trip": "[$1, $2]",
      "normalizer": "text"
    },
    {
      "name": "simple_object_round_trip",
      "description": "Simple object round-trip",
      "input": "{\"key\": $1}",
      "expected_round_trip": "{\"key\": $1}",
      "normalizer": "text"
    },
    {
      "name": "nested_array_round_trip",
      "description": "Nested array round-trip",
      "input": "[$1, [$2, $3]]",
      "expected_round_trip": "[$1, [$2, $3]]",
      "normalizer": "text"
    },
    {
      "name": "complex_object_round_trip",
      "description": "Complex object round-trip",
      "input": "{\"type\": \"array\", \"elements\": [$1, $2]}",
      "expected_round_trip": "{\"type\": \"array\", \"elements\": [$1, $2]}",
      "normalizer": "text"
    }
  ]
}
