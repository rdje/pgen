{
  "suite_name": "Semantic Annotations - Round-Trip Tests", 
  "description": "Round-trip testing: annotation syntax -> parse -> unparse -> compare",
  "parser_type": "semantic",
  "parser_config": {
    "debug_mode": false
  },
  "tests": [
    {
      "name": "dot_notation_round_trip",
      "description": "Dot notation round-trip",
      "input": "$1.bar",
      "expected_round_trip": "$1.bar",
      "normalizer": "text"
    },
    {
      "name": "array_access_round_trip",
      "description": "Array access round-trip", 
      "input": "$1[0]",
      "expected_round_trip": "$1[0]",
      "normalizer": "text"
    },
    {
      "name": "complex_chain_round_trip",
      "description": "Complex chained access round-trip",
      "input": "$1.items[*].value",
      "expected_round_trip": "$1.items[*].value", 
      "normalizer": "text"
    }
  ]
}
