{
  "parser_type": "semantic",
  "basic_tests": [
    {
      "input": "@optional_group: (identifier)?",
      "description": "Optional group - should preserve quantifier structure",
      "category": "optional_group",
      "expected": "success"
    },
    {
      "input": "@zero_or_more: (identifier)*",
      "description": "Zero-or-more quantified group - should preserve * quantifier",
      "category": "quantified_group", 
      "expected": "success"
    },
    {
      "input": "@one_or_more: (identifier)+",
      "description": "One-or-more quantified group - should preserve + quantifier",
      "category": "quantified_group",
      "expected": "success"
    },
    {
      "input": "@or_group: (\"a\" | \"b\" | \"c\")",
      "description": "OR group with multiple alternatives",
      "category": "or_group",
      "expected": "success"
    },
    {
      "input": "@nested_optional: ((identifier \",\" identifier)?)",
      "description": "Nested group with optional quantifier - complex structure",
      "category": "nested_group",
      "expected": "success"
    },
    {
      "input": "@sequence_quantified: (identifier /\\s*/ \",\" /\\s*/ identifier)*",
      "description": "Quantified sequence with regex whitespace - real-world pattern",
      "category": "complex_group",
      "expected": "success"
    }
  ],
  "complex_tests": [
    {
      "input": "@destructuring_parameter: (identifier_literal (/\\s*/ \",\" /\\s*/ identifier_literal)*)?",
      "description": "Complex destructuring parameter pattern - the exact pattern that fails",
      "category": "destructuring",
      "expected": "success"
    },
    {
      "input": "@nested_quantifiers: ((element \",\")*  | (element \";\")*)?",
      "description": "Nested quantifiers with OR alternatives - extremely complex",
      "category": "nested_complex",
      "expected": "success"
    },
    {
      "input": "@mixed_groups: (required_element (optional_element)? (repeating_element)*)",
      "description": "Mixed group types in sequence - optional and quantified",
      "category": "mixed_groups",
      "expected": "success"
    },
    {
      "input": "@regex_in_group: (/[a-zA-Z_][a-zA-Z0-9_]*/ (\".\" /[a-zA-Z_][a-zA-Z0-9_]*/)* )?",
      "description": "Regex patterns within complex groups - identifier path pattern",
      "category": "regex_groups",
      "expected": "success"
    },
    {
      "input": "@epsilon_issue: \"\"",
      "description": "Empty string should not be converted incorrectly to epsilon",
      "category": "epsilon_edge_case",
      "expected": "success"
    }
  ]
}