{
  "suite_name": "Semantic Annotations - Basic Tests",
  "description": "Basic tests for semantic annotation parser",
  "parser_type": "semantic",
  "parser_config": {
    "debug_mode": false
  },
  "tests": [
    {
      "name": "simple_dot_notation",
      "description": "Test basic dot notation",
      "input": "$1.bar",
      "expected": {
        "contains": ["bar", "dot_notation"]
      }
    },
    {
      "name": "nested_dot_notation",
      "description": "Test nested dot notation",
      "input": "$1.foo.bar",
      "expected": {
        "contains": ["foo", "bar"]
      }
    },
    {
      "name": "array_access",
      "description": "Test array access notation",
      "input": "$1[0]",
      "expected": {
        "contains": ["array_access", "[0]"]
      }
    },
    {
      "name": "complex_chain",
      "description": "Test complex chained notation",
      "input": "$1.items[*].value",
      "expected": {
        "contains": ["items", "[*]", "value"]
      }
    },
    {
      "name": "invalid_syntax",
      "description": "Test invalid syntax handling",
      "input": "$1..bar",
      "expected": {
        "error": "Parse"
      }
    }
  ]
}