{
  "suite_name": "Return Annotation - Basic Tests",
  "description": "Basic return annotation parser tests",
  "parser_type": "return",
  "tests": [
    {
      "name": "basic_scalar_$1",
      "description": "Basic scalar reference $1",
      "input": "$1",
      "expected": {
        "contains": ["ScalarRef", "1"]
      },
      "tags": ["basic", "scalar"]
    },
    {
      "name": "basic_scalar_$2",
      "description": "Basic scalar reference $2",
      "input": "$2",
      "expected": {
        "contains": ["ScalarRef", "2"]
      },
      "tags": ["basic", "scalar"]
    },
    {
      "name": "simple_array",
      "description": "Simple array [$1, $2]",
      "input": "[$1, $2]",
      "expected": {
        "contains": ["Array"]
      },
      "tags": ["basic", "array"]
    },
    {
      "name": "simple_object",
      "description": "Simple object {key: $1}",
      "input": "{key: $1}",
      "expected": {
        "contains": ["Object", "key"]
      },
      "tags": ["basic", "object"]
    },
    {
      "name": "string_literal",
      "description": "String literal",
      "input": "\"test\"",
      "expected": {
        "contains": ["StringLiteral", "test"]
      },
      "tags": ["basic", "literal"]
    }
  ]
}