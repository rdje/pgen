{
  "suite_name": "Return Annotations - Basic Positional References", 
  "description": "Tests for basic positional reference syntax ($1, $2, etc.)",
  "parser_type": "return",
  "tests": [
    {
      "name": "simple_positional_first",
      "description": "Basic first position reference",
      "input": "$1",
      "expected": {
        "contains": ["PositionalRef", "index: 1"]
      }
    },
    {
      "name": "simple_positional_second",
      "input": "$2", 
      "expected": {
        "contains": ["PositionalRef", "index: 2"]
      },
      "description": "Basic second position reference"
    },
    {
      "name": "simple_positional_large",
      "input": "$42",
      "expected": {
        "contains": ["PositionalRef", "index: 42"]
      },
      "description": "Large position number"
    },
    {
      "name": "positional_with_arrow",
      "input": "-> $3",
      "expected": {
        "contains": ["PositionalRef", "index: 3"]
      },
      "description": "Positional reference with arrow prefix"
    }
  ]
}
