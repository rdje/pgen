{
  "suite_name": "Return Annotations - Object Construction",
  "description": "Tests for object literal syntax",
  "parser_type": "return",
  "tests": [
    {
      "name": "simple_object",
      "input": "{key: $1, value: $2}",
      "expected": {
        "contains": ["Object", "key", "value", "PositionalRef"]
      },
      "description": "Simple object with positional references"
    },
    {
      "name": "object_with_literals",
      "input": "{type: \"array\", element: $3}",
      "expected": {
        "contains": ["Object", "type", "array", "element", "PositionalRef"]
      },
      "description": "Object with string literal and positional reference"
    },
    {
      "name": "empty_object",
      "input": "{}",
      "expected": {
        "contains": ["Object"]
      },
      "description": "Empty object literal"
    },
    {
      "name": "object_with_extraction",
      "input": "{params: [$1, $2::2*], count: $3}",
      "expected": {
        "contains": ["Object", "params", "Array", "QuantifiedExtraction", "count"]
      },
      "description": "Object with nested array containing extraction"
    }
  ]
}