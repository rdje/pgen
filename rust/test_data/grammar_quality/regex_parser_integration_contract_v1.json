{
  "version": 1,
  "integration_contract_version": "1.1.9",
  "parser_release_version": "1.1.9",
  "grammar": "regex",
  "profile": "regex_default",
  "required_generated_backend_flag": "supports_regex_generated_backend",
  "required_generated_backend_feature": "generated_parsers",
  "required_generated_backend_artifact": "generated/regex_parser.rs",
  "generated_backend_env_override": "PGEN_REGEX_PARSER_PATH",
  "ast_dump_schema_version": 1,
  "frontend_json_artifact": "generated/regex.json",
  "frontend_json_role": "PGEN-generated frontend normalization and provenance artifact; not a stable downstream runtime input or AST contract",
  "stable_diagnostic_location_fields": [
    "byte_offset",
    "line",
    "column"
  ],
  "success_samples": [
    {
      "name": "empty_regex",
      "input": ""
    },
    {
      "name": "alternation",
      "input": "a|b"
    },
    {
      "name": "word_boundary",
      "input": "\\bword\\b"
    },
    {
      "name": "url_pattern",
      "input": "https?://[^\\s]+"
    },
    {
      "name": "negated_posix_class",
      "input": "[[:^alnum:]]+"
    },
    {
      "name": "braced_named_backreference",
      "input": "(?<A>foo)-\\k{A}"
    },
    {
      "name": "numeric_backreference",
      "input": "(a)\\1",
      "required_rule_names": ["backreference"],
      "forbidden_rule_names": ["escape"]
    },
    {
      "name": "numeric_angle_subroutine_ref",
      "input": "\\g<1>",
      "required_rule_names": ["backreference", "subroutine_ref", "signed_digits"],
      "forbidden_rule_names": ["escape", "literal"]
    },
    {
      "name": "unicode_emoji_literal",
      "input": "🎉",
      "required_rule_names": ["literal"],
      "expected_rule_texts": {
        "literal": ["🎉"]
      }
    },
    {
      "name": "unicode_accented_literal",
      "input": "café",
      "required_rule_names": ["literal"],
      "expected_rule_texts": {
        "literal": ["c", "a", "f", "é"]
      }
    },
    {
      "name": "nested_capturing_groups_50",
      "input": "((((((((((((((((((((((((((((((((((((((((((((((((((a))))))))))))))))))))))))))))))))))))))))))))))))))",
      "required_rule_names": ["capturing_group", "literal"],
      "expected_rule_texts": {
        "literal": ["a"]
      }
    },
    {
      "name": "braced_octal_escape",
      "input": "\\o{101}",
      "required_rule_names": ["escape", "octal_escape", "octal_digits"],
      "forbidden_rule_names": ["simple_escape", "quantifier"]
    },
    {
      "name": "named_conditional",
      "input": "(?<A>a)?(?(A)b|c)",
      "required_rule_names": ["name"],
      "forbidden_rule_names": ["recursion_condition"]
    },
    {
      "name": "numeric_conditional",
      "input": "(?(1)a|b)",
      "required_rule_names": ["digits"],
      "forbidden_rule_names": ["recursion_condition", "name"]
    },
    {
      "name": "bare_recursion_conditional",
      "input": "(?(R)a|b)",
      "required_rule_names": ["recursion_condition"],
      "forbidden_rule_names": ["name"],
      "expected_rule_texts": {
        "recursion_condition": ["R"]
      }
    },
    {
      "name": "numeric_recursion_conditional",
      "input": "(a)(?(R1)b|c)",
      "required_rule_names": ["recursion_condition", "digits"],
      "forbidden_rule_names": ["name"],
      "expected_rule_texts": {
        "recursion_condition": ["R1"],
        "digits": ["1"]
      }
    },
    {
      "name": "named_recursion_conditional",
      "input": "(?(R&word)a|b)",
      "required_rule_names": ["recursion_condition", "name"],
      "expected_rule_texts": {
        "recursion_condition": ["R&word"],
        "name": ["word"]
      }
    },
    {
      "name": "whole_pattern_recursion",
      "input": "(?R)",
      "required_rule_names": ["subroutine_call", "subroutine_target"],
      "forbidden_rule_names": ["inline_modifiers"]
    },
    {
      "name": "returned_capture_numeric_subroutine",
      "input": "(?1(1))",
      "required_rule_names": [
        "subroutine_call",
        "returned_capture_subroutine",
        "subroutine_target",
        "returned_capture_group_list",
        "returned_capture_group",
        "signed_digits"
      ],
      "expected_rule_texts": {
        "returned_capture_subroutine": ["1(1)"],
        "subroutine_target": ["1"],
        "returned_capture_group_list": ["(1)"],
        "returned_capture_group": ["1"],
        "signed_digits": ["1", "1"]
      },
      "forbidden_rule_names": ["inline_modifiers"]
    },
    {
      "name": "returned_capture_named_subroutine",
      "input": "(?&callee(+1,<cap>,'alt'))",
      "required_rule_names": [
        "subroutine_call",
        "returned_capture_subroutine",
        "subroutine_target",
        "returned_capture_group_list",
        "returned_capture_group",
        "signed_digits",
        "name_ref",
        "name"
      ],
      "expected_rule_texts": {
        "subroutine_target": ["&callee"],
        "returned_capture_group_list": ["(+1,<cap>,'alt')"],
        "returned_capture_group": ["+1", "<cap>", "'alt'"],
        "signed_digits": ["+1"],
        "name_ref": ["<cap>", "'alt'"],
        "name": ["callee", "cap", "alt"]
      },
      "forbidden_rule_names": ["inline_modifiers"]
    },
    {
      "name": "left_open_counted_quantifier",
      "input": "a{,4}"
    },
    {
      "name": "literal_quantifier_binding",
      "input": "ab+"
    },
    {
      "name": "plain_embedded_code_block",
      "input": "(?{payload})",
      "required_rule_names": ["code_block_plain"],
      "forbidden_rule_names": ["code_block_lang", "code_lang"],
      "expected_rule_texts": {
        "code_content": ["payload"]
      }
    },
    {
      "name": "lua_embedded_code_block",
      "input": "(?{lua:return x + 1})",
      "required_rule_names": ["code_block_lang", "code_lang"],
      "forbidden_rule_names": ["code_block_plain"],
      "expected_rule_texts": {
        "code_lang": ["lua"],
        "code_content": ["return x + 1"]
      }
    },
    {
      "name": "rhai_embedded_code_block",
      "input": "(?{rhai:let x = 1;})",
      "required_rule_names": ["code_block_lang", "code_lang"],
      "forbidden_rule_names": ["code_block_plain"],
      "expected_rule_texts": {
        "code_lang": ["rhai"],
        "code_content": ["let x = 1;"]
      }
    },
    {
      "name": "native_embedded_code_block",
      "input": "(?{native:callback_name})",
      "required_rule_names": ["code_block_lang", "code_lang"],
      "forbidden_rule_names": ["code_block_plain"],
      "expected_rule_texts": {
        "code_lang": ["native"],
        "code_content": ["callback_name"]
      }
    },
    {
      "name": "wasm_embedded_code_block",
      "input": "(?{wasm:module:function})",
      "required_rule_names": ["code_block_lang", "code_lang"],
      "forbidden_rule_names": ["code_block_plain"],
      "expected_rule_texts": {
        "code_lang": ["wasm"],
        "code_content": ["module:function"]
      }
    },
    {
      "name": "javascript_embedded_code_block",
      "input": "(?{javascript:return x + 1;})",
      "required_rule_names": ["code_block_lang", "code_lang"],
      "forbidden_rule_names": ["code_block_plain"],
      "expected_rule_texts": {
        "code_lang": ["javascript"],
        "code_content": ["return x + 1;"]
      }
    }
  ],
  "failure_samples": [
    {
      "name": "unbalanced_group",
      "input": "("
    },
    {
      "name": "unclosed_char_class",
      "input": "[a-"
    },
    {
      "name": "invalid_counted_quantifier_bounds",
      "input": "x{5,4}"
    },
    {
      "name": "invalid_char_class_escape",
      "input": "[\\B]"
    },
    {
      "name": "descending_char_class_range",
      "input": "[z-a]"
    },
    {
      "name": "quantified_anchor",
      "input": "^+"
    },
    {
      "name": "variable_length_lookbehind",
      "input": "(?<=a+)b"
    },
    {
      "name": "unsupported_escape_i",
      "input": "ab\\idef"
    }
  ]
}
