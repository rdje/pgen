{
  "version": 4,
  "description": "Phase O VHDL pre-merge quality contract for deterministic closed-loop stimuli generation, parser-backed sample generation telemetry, closed-loop replay parseability shadow telemetry, optional parse-full validation, and realistic curated corpus checks.",
  "grammar_name": "vhdl",
  "ebnf_path": "grammars/vhdl.ebnf",
  "entry_rule": "vhdl_file",
  "sample_count": 8,
  "seed_base": 22001,
  "closed_loop": {
    "enabled": true,
    "gap_report_threshold": 1,
    "target_max_attempts": 5000,
    "replay_sample_count": 8,
    "require_non_increasing_target_debt": true,
    "parseability_shadow_enabled": true
  },
  "parseability_generation": {
    "enabled": true,
    "max_attempts_per_sample": 50
  },
  "realistic_corpus": {
    "enforce": true,
    "cases_path": "rust/test_data/grammar_quality/vhdl_realistic_corpus_v0.json",
    "max_parse_full_ms_per_case": 15000,
    "max_sample_bytes": 131072
  }
}
