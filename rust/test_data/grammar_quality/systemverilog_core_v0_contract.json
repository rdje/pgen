{
  "version": 12,
  "description": "Phase Q/P preprocessor-first contract for SystemVerilog stimuli quality checks with deterministic closed-loop coverage/gap replay, structural semantic baseline checks, semantic-closure validator toggles, dual LRM profile matrix support, explicit stimuli modes (including preprocess-aware and semantic-closure file modes), deterministic failure replay/shrinking, basic port-binding legality checks, mode-level semantic override profiles, and mode-level stimuli steering policy.",
  "grammar_name": "systemverilog",
  "ebnf_path": "grammars/systemverilog.ebnf",
  "sample_count": 6,
  "seed_base": 12001,
  "lrm_profiles": {
    "default_profile": "2017",
    "supported_profiles": ["2017", "2023"],
    "required_profiles": ["2017", "2023"]
  },
  "stimuli_modes": {
    "default_mode": "sv_file",
    "supported_modes": ["sv_file", "sv_snippet", "sv_pp_file", "sv_pp_snippet", "sv_semantic_file"],
    "profiles": {
      "sv_file": {
        "entry_rule": "systemverilog_file",
        "closed_loop_enabled": true,
        "parse_full_eligible": true,
        "recovery_stimuli_mode": "baseline",
        "semantic_overrides": {
          "require_port_binding_legality_basic": true
        }
      },
      "sv_snippet": {
        "entry_rule": "source_item",
        "closed_loop_enabled": false,
        "parse_full_eligible": false,
        "recovery_stimuli_mode": "near_sync_negative",
        "semantic_overrides": {
          "require_port_binding_legality_basic": false
        }
      },
      "sv_pp_file": {
        "entry_rule": "systemverilog_file",
        "closed_loop_enabled": true,
        "parse_full_eligible": true,
        "recovery_stimuli_mode": "recovery_biased",
        "semantic_overrides": {
          "require_port_binding_legality_basic": true,
          "require_no_preprocess_errors": true
        }
      },
      "sv_pp_snippet": {
        "entry_rule": "source_item",
        "closed_loop_enabled": false,
        "parse_full_eligible": false,
        "recovery_stimuli_mode": "near_sync_negative",
        "semantic_overrides": {
          "require_port_binding_legality_basic": false,
          "require_no_preprocess_errors": true
        }
      },
      "sv_semantic_file": {
        "entry_rule": "systemverilog_file",
        "closed_loop_enabled": true,
        "parse_full_eligible": true,
        "recovery_stimuli_mode": "baseline",
        "semantic_overrides": {
          "require_port_binding_legality_basic": true,
          "require_package_qualification_resolution": true,
          "require_context_legality_basic": true
        }
      }
    }
  },
  "closed_loop": {
    "enabled": true,
    "gap_report_threshold": 1,
    "target_max_attempts": 5000,
    "replay_sample_count": 6,
    "require_non_increasing_target_debt": true
  },
  "failure_replay": {
    "enabled": true,
    "shrink_semantic_failures": true,
    "shrink_parse_full_failures": true,
    "shrink_max_iterations": 24
  },
  "preprocess": {
    "include_max_depth": 64,
    "include_path_policy": "allow_absolute",
    "macro_redefine_policy": "warn",
    "conditional_symbol_policy": "assume_false_warn",
    "conditional_expr_policy": "identifier_or_defined",
    "strict_warning_codes": "none"
  },
  "semantic_baseline": {
    "require_nonempty_preprocessed_output": true,
    "require_no_preprocess_errors": true,
    "require_balanced_structural_keywords": false,
    "require_unique_named_port_bindings": true,
    "require_port_binding_legality_basic": false,
    "require_declared_identifiers_before_use": false,
    "require_package_qualification_resolution": false,
    "require_width_compatibility_simple": false,
    "require_context_legality_basic": false
  }
}
