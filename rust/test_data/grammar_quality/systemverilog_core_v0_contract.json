{
  "version": 5,
  "description": "Phase Q/P preprocessor-first contract for SystemVerilog stimuli quality checks with deterministic closed-loop coverage/gap replay, structural semantic baseline checks, semantic-closure validator toggles, and dual LRM profile matrix support.",
  "grammar_name": "systemverilog",
  "ebnf_path": "grammars/systemverilog.ebnf",
  "sample_count": 6,
  "seed_base": 12001,
  "lrm_profiles": {
    "default_profile": "2017",
    "supported_profiles": ["2017", "2023"],
    "required_profiles": ["2017", "2023"]
  },
  "closed_loop": {
    "enabled": true,
    "gap_report_threshold": 1,
    "target_max_attempts": 5000,
    "replay_sample_count": 6,
    "require_non_increasing_target_debt": true
  },
  "preprocess": {
    "include_max_depth": 64,
    "include_path_policy": "allow_absolute",
    "macro_redefine_policy": "warn",
    "conditional_symbol_policy": "assume_false_warn",
    "conditional_expr_policy": "identifier_or_defined",
    "strict_warning_codes": "none"
  },
  "semantic_baseline": {
    "require_nonempty_preprocessed_output": true,
    "require_no_preprocess_errors": true,
    "require_balanced_structural_keywords": false,
    "require_unique_named_port_bindings": true,
    "require_declared_identifiers_before_use": false,
    "require_package_qualification_resolution": false,
    "require_width_compatibility_simple": false,
    "require_context_legality_basic": false
  }
}
