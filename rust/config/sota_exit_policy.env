PGEN_SOTA_POLICY_VERSION=1

# Required checks executed by the aggregate SOTA release gate.
PGEN_SOTA_POLICY_REQUIRED_CHECKS="differential_baseline_contract fixed_point_gate annotation_contract_gate annotation_100_gate annotation_nonbootstrap_e2e_gate ebnf_stimuli_quality_gate stimuli_module_parity_gate differential_regression_gate performance_gate embedding_api_gate"

# EBNF frontend strict readiness is now required in aggregate SOTA runs.
PGEN_SOTA_POLICY_RUN_EBNF_READINESS=1
PGEN_SOTA_POLICY_REQUIRE_EBNF_STRICT=1

# Run Perl-vs-Rust EBNF dual-run differential as required strict check in aggregate SOTA runs.
PGEN_SOTA_POLICY_RUN_EBNF_DUAL_RUN_DIFF=1
PGEN_SOTA_POLICY_REQUIRE_EBNF_DUAL_RUN_STRICT=1

# Run HDL frontend readiness as required strict now that both seed grammars pass strict gate.
PGEN_SOTA_POLICY_RUN_HDL_FRONTEND_READINESS=1
PGEN_SOTA_POLICY_REQUIRE_HDL_FRONTEND_STRICT=1

# Run SystemVerilog preprocessor quality gate in informational mode during early Phase Q closure.
PGEN_SOTA_POLICY_RUN_SV_PREPROCESSOR_QUALITY=1
PGEN_SOTA_POLICY_REQUIRE_SV_PREPROCESSOR_QUALITY_STRICT=0

# Run SystemVerilog stimuli quality gate in informational mode while parse_full and semantic closure continue to harden.
PGEN_SOTA_POLICY_RUN_SV_STIMULI_QUALITY=1
PGEN_SOTA_POLICY_REQUIRE_SV_STIMULI_QUALITY_STRICT=0

# Informational checks may fail without failing the aggregate gate.
PGEN_SOTA_POLICY_ALLOW_INFORMATIONAL_FAILURES=1
