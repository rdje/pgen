# rtl_frontend.ebnf
#
# Phase S bootstrap grammar for the synthesizable RTL subset currently owned by
# the handwritten `rtl_frontend` crate.
#
# Scope intentionally matches the current RTLSyn-facing baseline:
# - file-scope typedefs, packages, and modules
# - module header imports, parameter lists, and ANSI port lists
# - parameter/localparam declarations, typedefs, imports, genvars, and net declarations
# - continuous assigns, `always` / `always_comb` / `always_ff` / `always_latch`
# - generate regions with `if` / `for` constructs
# - module instantiations with named/ordered overrides and named/ordered/wildcard port connections
# - enum / struct / union types plus builtin and package-qualified types
# - value / target expressions for signals, members, selects, concatenations, repetitions, and
#   the same unary/binary/ternary constant-expression core already used by `rtl_const_expr`

@branch_policy: priority_first
rtl_frontend_file := trivia design_item* trivia
-> {type: "rtl_frontend_file", items: $2}

@branch_policy: priority_first
design_item := typedef_declaration -> {kind: "typedef",  body: $1}
             | package_declaration -> {kind: "package",  body: $1}
             | module_declaration  -> {kind: "module",   body: $1}
             | semi                -> {kind: "semi"}

package_declaration := kw_package identifier semi package_item* kw_endpackage
                    -> {name: $2, items: $4}

@branch_policy: priority_first
package_item := typedef_declaration               -> {kind: "typedef", body: $1}
              | parameter_declaration_statement   -> {kind: "parameter", body: $1}
              | semi                              -> {kind: "semi"}

module_declaration := kw_module identifier import_declaration* ( hash lparen ( parameter_declaration_sequence )? rparen )? import_declaration* ( lparen ( port_list )? rparen )? semi module_item* kw_endmodule
                   -> {name: $2, imports_pre: $3, parameters: $4, imports_post: $5, ports: $6, items: $8}

@branch_policy: priority_first
module_item := parameter_declaration_statement -> {kind: "parameter",           body: $1}
             | import_declaration               -> {kind: "import",              body: $1}
             | typedef_declaration              -> {kind: "typedef",             body: $1}
             | genvar_declaration               -> {kind: "genvar",              body: $1}
             | module_instantiation             -> {kind: "module_instantiation", body: $1}
             | net_declaration                  -> {kind: "net",                 body: $1}
             | continuous_assign                -> {kind: "continuous_assign",   body: $1}
             | procedural_block                 -> {kind: "procedural_block",    body: $1}
             | generate_region                  -> {kind: "generate_region",     body: $1}
             | semi                             -> {kind: "semi"}

generate_region := kw_generate generate_item* kw_endgenerate
                -> {items: $2}

@branch_policy: priority_first
generate_item := parameter_declaration_statement -> {kind: "parameter",           body: $1}
               | import_declaration               -> {kind: "import",              body: $1}
               | typedef_declaration              -> {kind: "typedef",             body: $1}
               | genvar_declaration               -> {kind: "genvar",              body: $1}
               | module_instantiation             -> {kind: "module_instantiation", body: $1}
               | net_declaration                  -> {kind: "net",                 body: $1}
               | continuous_assign                -> {kind: "continuous_assign",   body: $1}
               | procedural_block                 -> {kind: "procedural_block",    body: $1}
               | generate_if                      -> {kind: "generate_if",         body: $1}
               | generate_for                     -> {kind: "generate_for",        body: $1}
               | semi                             -> {kind: "semi"}

generate_if := kw_if lparen rtl_expr rparen generate_body ( kw_else generate_body )?
            -> {cond: $3, then_body: $5, else_body: $6}

generate_for := kw_for lparen ( kw_genvar )? identifier equals rtl_expr semi rtl_expr semi identifier equals rtl_expr rparen generate_body
             -> {genvar: $3, init_var: $4, init_value: $6, condition: $8, step_var: $10, step_value: $12, body: $14}

@branch_policy: priority_first
generate_body := kw_begin ( colon identifier )? generate_item* kw_end  -> {kind: "block",  label: $2, items: $3}
               | generate_item                                          -> {kind: "single", body: $1}

parameter_declaration_statement := parameter_declaration_sequence semi
                                -> {body: $1}

parameter_declaration_sequence := parameter_declaration_group ( comma parameter_declaration_group )*
                               -> {first: $1, rest: $2}

parameter_declaration_group := parameter_declaration_head ( comma parameter_declaration_tail )*
                            -> {head: $1, tail: $2}

@branch_policy: priority_first
parameter_declaration_head := parameter_flavor &( data_type identifier ) data_type identifier ( equals rtl_expr )?  -> {kind: "typed",   flavor: $1, data_type: $3, name: $4, default: $5}
                            | parameter_flavor identifier ( equals rtl_expr )?                                       -> {kind: "untyped", flavor: $1, name: $2, default: $3}

@branch_policy: priority_first
parameter_declaration_tail := parameter_flavor &( data_type identifier ) data_type identifier ( equals rtl_expr )?  -> {kind: "typed_with_flavor",   flavor: $1, data_type: $3, name: $4, default: $5}
                            | parameter_flavor identifier ( equals rtl_expr )?                                       -> {kind: "untyped_with_flavor", flavor: $1, name: $2, default: $3}
                            | &( data_type identifier ) data_type identifier ( equals rtl_expr )?                    -> {kind: "typed",   data_type: $2, name: $3, default: $4}
                            | identifier ( equals rtl_expr )?                                                        -> {kind: "untyped", name: $1, default: $2}

parameter_flavor := kw_parameter   -> {kind: "parameter"}
                 | kw_localparam  -> {kind: "localparam"}

port_list := port_group ( comma port_group )*
          -> {first: $1, rest: $2}

port_group := port_direction data_type? packed_range? port_item ( comma !port_direction_token port_item )*
           -> {direction: $1, data_type: $2, packed_range: $3, first: $4, rest: $5}

port_item := identifier unpacked_dimension*
          -> {name: $1, dims: $2}

port_direction := kw_input   -> {kind: "input"}
               | kw_output  -> {kind: "output"}
               | kw_inout   -> {kind: "inout"}
port_direction_token := kw_input   -> {kind: "input"}
                     | kw_output  -> {kind: "output"}
                     | kw_inout   -> {kind: "inout"}

import_declaration := kw_import identifier scope_resolution ( star | identifier ) semi
                   -> {package: $2, member: $4}

typedef_declaration := kw_typedef data_type packed_range? identifier semi
                   -> {data_type: $2, packed_range: $3, name: $4}

genvar_declaration := kw_genvar identifier ( comma identifier )* semi
                  -> {first: $2, rest: $3}

module_instantiation := identifier ( hash lparen ( parameter_override_list )? rparen )? instance_item ( comma instance_item )* semi
                     -> {module_name: $1, parameters: $2, first: $3, rest: $4}

instance_item := identifier unpacked_dimension? lparen ( port_connection_list )? rparen
              -> {name: $1, dims: $2, connections: $4}

parameter_override_list := &dot parameter_override ( comma &dot parameter_override )*   -> {kind: "named",      first: $2, rest: $3}
                         | !dot parameter_override ( comma !dot parameter_override )*   -> {kind: "positional", first: $2, rest: $3}

@branch_policy: priority_first
parameter_override := dot identifier lparen rtl_expr rparen  -> {kind: "named",     name: $2, value: $4}
                    | rtl_expr                                -> {kind: "positional", value: $1}

port_connection_list := &dot port_connection ( comma &dot port_connection )*   -> {kind: "named",      first: $2, rest: $3}
                      | !dot port_connection ( comma !dot port_connection )*   -> {kind: "positional", first: $2, rest: $3}

@branch_policy: priority_first
port_connection := dot star                                       -> {kind: "wildcard"}
                 | dot identifier lparen ( value_expr )? rparen   -> {kind: "named",      name: $2, value: $4}
                 | value_expr                                      -> {kind: "positional", value: $1}

net_declaration := data_type packed_range? net_item ( comma net_item )* semi
                -> {data_type: $1, packed_range: $2, first: $3, rest: $4}

net_item := identifier unpacked_dimension*
         -> {name: $1, dims: $2}

continuous_assign := kw_assign assignment_target equals value_expr semi
                  -> {lvalue: $2, value: $4}

@branch_policy: priority_first
procedural_block := kw_always_comb statement                              -> {kind: "always_comb",  statement: $2}
                  | kw_always_latch statement                              -> {kind: "always_latch", statement: $2}
                  | kw_always_ff event_control_list always_ff_statement    -> {kind: "always_ff",    event_control: $2, statement: $3}
                  | kw_always always_star_event statement                  -> {kind: "always",       event: $2, statement: $3}

always_star_event := at lparen star rparen   -> {kind: "at_paren_star"}
                  | star                    -> {kind: "bare_star"}

event_control_list := at lparen event_control_item ( ( comma | kw_or ) event_control_item )* rparen
                   -> {first: $3, rest: $4}

event_control_item := event_edge? rtl_expr
                  -> {edge: $1, expr: $2}

event_edge := kw_posedge  -> {kind: "posedge"}
           | kw_negedge  -> {kind: "negedge"}

@branch_policy: priority_first
statement := semi                                                                        -> {kind: "semi"}
          | kw_begin ( colon identifier )? statement* kw_end                              -> {kind: "block",      label: $2, items: $3}
          | kw_if lparen rtl_expr rparen statement ( kw_else statement )?                 -> {kind: "if",         cond: $3, then_body: $5, else_body: $6}
          | assignment_target assignment_operator value_expr semi                         -> {kind: "assignment", lvalue: $1, operator: $2, value: $3}

@branch_policy: priority_first
always_ff_statement := semi                                                                        -> {kind: "semi"}
                    | kw_begin ( colon identifier )? always_ff_statement* kw_end                    -> {kind: "block",      label: $2, items: $3}
                    | kw_if lparen rtl_expr rparen always_ff_statement ( kw_else always_ff_statement )? -> {kind: "if",         cond: $3, then_body: $5, else_body: $6}
                    | assignment_target always_ff_assignment_operator value_expr semi               -> {kind: "assignment", lvalue: $1, operator: $2, value: $3}

always_ff_assignment_operator := less_equal

assignment_operator := equals      -> {kind: "blocking"}
                    | less_equal  -> {kind: "nonblocking"}

@branch_policy: priority_first
assignment_target := lbrace assignment_target ( comma assignment_target )+ rbrace  -> {kind: "concat",  first: $2, rest: $3}
                   | ranged_signal_reference                                         -> {kind: "ranged",  body: $1}
                   | signal_reference                                                -> {kind: "signal",  body: $1}

value_expr := rtl_expr

rtl_expr := conditional_expr

conditional_expr := logical_or_expr question conditional_expr colon conditional_expr  -> {type: "ternary",  condition: $1, then_expr: $3, else_expr: $5}
                  | logical_or_expr                                                    -> $1

logical_or_expr := logical_and_expr ( logical_or logical_and_expr )*
                -> {type: "binop_chain", level: "logical_or",   lhs: $1, rest: $2}
logical_and_expr := bit_or_expr ( logical_and bit_or_expr )*
                 -> {type: "binop_chain", level: "logical_and",  lhs: $1, rest: $2}
bit_or_expr := bit_xor_expr ( bit_or bit_xor_expr )*
            -> {type: "binop_chain", level: "bit_or",       lhs: $1, rest: $2}
bit_xor_expr := bit_and_expr ( bit_xor bit_and_expr )*
             -> {type: "binop_chain", level: "bit_xor",      lhs: $1, rest: $2}
bit_and_expr := equality_expr ( bit_and equality_expr )*
             -> {type: "binop_chain", level: "bit_and",      lhs: $1, rest: $2}
# Operator-precedence levels. The five multi-token operator alternations
# are lifted into NAMED rules (the gate-locked rtl_const_expr / mature
# systemverilog.ebnf `binary_operator` idiom). An inline alternation
# `( a | b )` as the lead element of the `( ... next )*` iteration
# corrupted the positional model so bare `rest:$2` emitted
# `<invalid_sequence_access>` (the systemic inline-alternation-$N defect
# class; same as RTL-CE-0001 / SVPP-0001). The named op-rules keep the
# annotation unchanged and yield a clean `[op-envelope, operand]` rest.
equality_expr := relational_expr ( equality_op relational_expr )*
              -> {type: "binop_chain", level: "equality",    lhs: $1, rest: $2}
relational_expr := shift_expr ( relational_op shift_expr )*
                -> {type: "binop_chain", level: "relational",  lhs: $1, rest: $2}
shift_expr := additive_expr ( shift_op additive_expr )*
           -> {type: "binop_chain", level: "shift",        lhs: $1, rest: $2}
additive_expr := multiplicative_expr ( additive_op multiplicative_expr )*
              -> {type: "binop_chain", level: "additive",     lhs: $1, rest: $2}
multiplicative_expr := unary_expr ( multiplicative_op unary_expr )*
                    -> {type: "binop_chain", level: "multiplicative", lhs: $1, rest: $2}

equality_op       := eqeq | ne
relational_op     := less_equal | lt | ge | gt
shift_op          := shl | shr
additive_op       := plus | minus
multiplicative_op := star | slash | percent

unary_expr := plus unary_expr     -> {type: "unary", op: "plus",        expr: $2}
           | minus unary_expr    -> {type: "unary", op: "minus",       expr: $2}
           | bang unary_expr     -> {type: "unary", op: "logical_not", expr: $2}
           | tilde unary_expr    -> {type: "unary", op: "bit_not",     expr: $2}
           | primary_expr        -> $1

@branch_policy: priority_first
primary_expr := repetition_expr             -> {kind: "repetition",    body: $1}
             | concatenation_expr           -> {kind: "concatenation", body: $1}
             | ranged_signal_reference      -> {kind: "ranged_signal", body: $1}
             | signal_reference             -> {kind: "signal",        body: $1}
             | literal                      -> {kind: "literal",       body: $1}
             | lparen rtl_expr rparen       -> {kind: "parens",        expr: $2}

repetition_expr := lbrace rtl_expr lbrace rtl_expr ( comma rtl_expr )* rbrace rbrace
                -> {count: $2, first: $4, rest: $5}

concatenation_expr := lbrace rtl_expr ( comma rtl_expr )+ rbrace
                   -> {first: $2, rest: $3}

ranged_signal_reference := scoped_identifier signal_path_op* lbrack rtl_expr colon rtl_expr rbrack
                        -> {name: $1, path: $2, msb: $4, lsb: $6}

signal_reference := scoped_identifier signal_path_op*
                 -> {name: $1, path: $2}

scoped_identifier := identifier ( scope_resolution identifier )*
                  -> {first: $1, rest: $2}

signal_path_op := dot identifier        -> {kind: "member", name: $2}
               | lbrack rtl_expr rbrack -> {kind: "index",  index: $2}

data_type := enum_type              -> {kind: "enum",     body: $1}
           | union_type             -> {kind: "union",    body: $1}
           | struct_type            -> {kind: "struct",   body: $1}
           | builtin_data_type      -> {kind: "builtin",  body: $1}
           | package_qualified_type -> {kind: "package",  body: $1}
           | named_data_type        -> {kind: "named",    body: $1}

package_qualified_type := identifier scope_resolution identifier
                       -> {package: $1, name: $3}

named_data_type := identifier

builtin_data_type := kw_bit       -> {kind: "bit"}
                   | kw_byte      -> {kind: "byte"}
                   | kw_shortint  -> {kind: "shortint"}
                   | kw_int       -> {kind: "int"}
                   | kw_integer   -> {kind: "integer"}
                   | kw_longint   -> {kind: "longint"}
                   | kw_logic     -> {kind: "logic"}
                   | kw_reg       -> {kind: "reg"}
                   | kw_wire      -> {kind: "wire"}

enum_type := kw_enum ( enum_base_type )? packed_range? lbrace enum_item ( comma enum_item )* ( comma )? rbrace
          -> {base: $2, packed_range: $3, first: $5, rest: $6}

enum_base_type := builtin_data_type      -> {kind: "builtin", body: $1}
               | package_qualified_type -> {kind: "package", body: $1}
               | named_data_type        -> {kind: "named",   body: $1}

enum_item := identifier ( equals rtl_expr )?
          -> {name: $1, value: $2}

union_type := kw_union ( kw_packed )? lbrace struct_union_field* rbrace
           -> {packed: $2, fields: $4}

struct_type := kw_struct ( kw_packed )? lbrace struct_union_field* rbrace
            -> {packed: $2, fields: $4}

struct_union_field := data_type packed_range? struct_union_field_name ( comma struct_union_field_name )* semi
                   -> {data_type: $1, packed_range: $2, first: $3, rest: $4}

struct_union_field_name := identifier   -> {kind: "identifier", body: $1}
                        | kw_byte      -> {kind: "byte"}

packed_range := lbrack rtl_expr colon rtl_expr rbrack
             -> {msb: $2, lsb: $4}
unpacked_dimension := packed_range

literal := based_integer    -> {kind: "based",   text: $1}
        | decimal_integer  -> {kind: "decimal", text: $1}
        | real_number      -> {kind: "real",    body: $1}

based_integer := trivia /[0-9][0-9_]*'[sS]?[bBoOdDhH][0-9a-fA-FxXzZ?_]+/
decimal_integer := trivia /[0-9][0-9_]*/
real_number := trivia /[0-9][0-9_]*\.[0-9][0-9_]*([eE][+-]?[0-9][0-9_]*)?/ | trivia /[0-9][0-9_]*([eE][+-]?[0-9][0-9_]*)/

identifier := non_keyword_identifier

non_keyword_identifier := !kw_always !kw_always_comb !kw_always_ff !kw_always_latch !kw_assign !kw_begin !kw_bit !kw_byte !kw_else !kw_end !kw_endgenerate !kw_endmodule !kw_endpackage !kw_enum !kw_for !kw_generate !kw_genvar !kw_if !kw_import !kw_inout !kw_input !kw_int !kw_integer !kw_localparam !kw_logic !kw_longint !kw_module !kw_negedge !kw_or !kw_output !kw_package !kw_packed !kw_parameter !kw_posedge !kw_reg !kw_shortint !kw_struct !kw_typedef !kw_union !kw_wire simple_identifier

simple_identifier := trivia /[A-Za-z_][A-Za-z0-9_$]*/

trivia := ( white_space | line_comment | block_comment )*
white_space := /[ \t\r\n]+/
line_comment := /\/\/[^\r\n]*/
block_comment := /\/\*([^*]|\*+[^*\/])*\*+\//

kw_module := trivia "module"
kw_endmodule := trivia "endmodule"
kw_package := trivia "package"
kw_endpackage := trivia "endpackage"
kw_import := trivia "import"
kw_typedef := trivia "typedef"
kw_parameter := trivia "parameter"
kw_localparam := trivia "localparam"
kw_genvar := trivia "genvar"
kw_assign := trivia "assign"
kw_generate := trivia "generate"
kw_endgenerate := trivia "endgenerate"
kw_if := trivia "if"
kw_else := trivia "else"
kw_for := trivia "for"
kw_begin := trivia "begin"
kw_end := trivia "end"
kw_always := trivia "always"
kw_always_comb := trivia "always_comb"
kw_always_ff := trivia "always_ff"
kw_always_latch := trivia "always_latch"
kw_posedge := trivia "posedge"
kw_negedge := trivia "negedge"
kw_or := trivia "or"
kw_input := trivia "input"
kw_output := trivia "output"
kw_inout := trivia "inout"
kw_struct := trivia "struct"
kw_union := trivia "union"
kw_enum := trivia "enum"
kw_packed := trivia "packed"
kw_bit := trivia "bit"
kw_byte := trivia "byte"
kw_shortint := trivia "shortint"
kw_int := trivia "int"
kw_integer := trivia "integer"
kw_longint := trivia "longint"
kw_logic := trivia "logic"
kw_reg := trivia "reg"
kw_wire := trivia "wire"

scope_resolution := trivia "::"
dot := trivia "."
hash := trivia "#"
lparen := trivia "("
rparen := trivia ")"
lbrace := trivia "{"
rbrace := trivia "}"
lbrack := trivia "["
rbrack := trivia "]"
comma := trivia ","
colon := trivia ":"
semi := trivia ";"
question := trivia "?"
at := trivia "@"

logical_or := trivia "||"
logical_and := trivia "&&"
bit_or := trivia "|"
bit_xor := trivia "^"
bit_and := trivia "&"
eqeq := trivia "=="
ne := trivia "!="
less_equal := trivia "<="
lt := trivia "<"
ge := trivia ">="
gt := trivia ">"
shl := trivia "<<"
shr := trivia ">>"
plus := trivia "+"
minus := trivia "-"
star := trivia "*"
slash := trivia "/"
percent := trivia "%"
bang := trivia "!"
tilde := trivia "~"
equals := trivia "="
