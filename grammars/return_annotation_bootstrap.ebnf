# return_annotation_bootstrap.ebnf
#
# Bootstrap Mode Return Annotation Grammar
# =========================================
#
# This grammar precisely documents the LIMITED subset of return annotations
# that are supported by the built-in ReturnAnnotationHandler when operating
# in Bootstrap mode. This is used for self-hosted parsers (semantic_annotation_parser
# and return_annotation_parser) to avoid circular dependencies.
#
# IMPORTANT: This is NOT the full return annotation grammar. For the complete
# grammar with all advanced features, see return_annotation.ebnf
#
# Bootstrap mode supports only:
# - Scalar references: $1, $2, $99
# - String literals: "value"
# - Arrays: [$1, $2], with spread operator: [$1, $3*]
# - Objects: {key: value}
# - NO dot notation, NO array slicing, NO complex nesting
#
# The -> prefix is handled by the handler, not part of this grammar

# Root rule - a bootstrap return annotation (without -> prefix)
return_annotation := scalar_ref | string_literal | array | object

# Scalar reference: $1, $2, $10, $99
scalar_ref := "$" /([0-9]+)/

# String literal: "text" (double quotes only in bootstrap)
string_literal := /"([^"\\]|\\.)*"/

# Array: [], [$1], [$1, $2], [$1, $3*]
array := "[" array_elements? "]"

# Array elements (comma-separated)
array_elements := array_element ("," array_element)*

# Individual array element - can be spread with *
array_element := (scalar_ref | string_literal | array | object) spread_operator?

# Spread operator for arrays: * (as in $3*)
spread_operator := "*"

# Object: {}, {key: value}, {key1: value1, key2: value2}
object := "{" object_properties? "}"

# Object properties (comma-separated key-value pairs)
object_properties := object_property ("," object_property)*

# Individual object property
# Keys can be unquoted identifiers or quoted strings
# Values are any valid annotation element
object_property := property_key ":" property_value

# Property key - unquoted identifier (bootstrap mode allows this)
property_key := /([a-zA-Z_][a-zA-Z0-9_]*)/

# Property value - any valid annotation element
property_value := scalar_ref | string_literal | array | object

# ===========================================================================
# LIMITATIONS IN BOOTSTRAP MODE
# ===========================================================================
#
# The following features are NOT supported in bootstrap mode:
#
# 1. Dot notation access: $1.property, $2.field.subfield
# 2. Array indexing: $1[0], $2[1]
# 3. Array slicing: $1[1:3], $1[*], $1[:], $1[0..2]
# 4. Negative indexing: $1[-1]
# 5. Multiple indices: $1[1,3,5]
# 6. Quantifiers on entire annotations: [$1]*, {key: $1}+, [$1]?
# 7. Repetition counts: {count: $1}{3}, {data: $1}{2,5}
# 8. Complex nested structures beyond simple arrays/objects
# 9. Number literals without quotes (only string literals supported)
# 10. Boolean literals (true/false)
# 11. Null values
# 12. Single-quoted strings
#
# ===========================================================================
# SPECIAL HANDLING NOTES
# ===========================================================================
#
# 1. The -> prefix is stripped by ReturnAnnotationHandler before parsing
# 2. Spread operator (*) is only supported for array elements, not objects
# 3. Object keys can be unquoted identifiers (not requiring quotes)
# 4. Deep nesting is technically parsed but not fully supported in code generation
# 5. The handler defaults to Passthrough for unrecognized patterns
#
# ===========================================================================
# EXAMPLES OF VALID BOOTSTRAP ANNOTATIONS
# ===========================================================================
#
# Simple scalars:
#   $1
#   $2
#   $99
#
# Arrays:
#   []
#   [$1]
#   [$1, $2]
#   [$1, $3*]              # Spread operator
#   [[$1, $2], [$3, $4]]   # Nested arrays (parsed but limited codegen)
#
# Objects:
#   {}
#   {key: $1}
#   {type: "array", value: $2}
#   {name: $1, items: [$2, $3*]}
#   {outer: {inner: $1}}   # Nested objects (parsed but limited codegen)
#
# String literals:
#   "literal"
#   "some text"
#
# ===========================================================================