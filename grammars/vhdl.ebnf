# vhdl.ebnf
#
# Initial VHDL seed grammar focused on executable frontend readiness.
# Scope:
# - design units: library/use/entity/architecture/package/package body/configuration/context
# - entity generics/ports
# - architecture declarations and concurrent statements baseline
# - process + core sequential statements
# - expression/type/literal baseline

vhdl_file := design_unit*
-> {type: "vhdl_file", design_units: $1}

design_unit := library_clause              -> {kind: "library",                   body: $1}
             | use_clause                  -> {kind: "use",                       body: $1}
             | context_reference_clause    -> {kind: "context_reference",         body: $1}
             | entity_declaration          -> {kind: "entity",                    body: $1}
             | architecture_body           -> {kind: "architecture",              body: $1}
             | package_declaration         -> {kind: "package",                   body: $1}
             | package_body                -> {kind: "package_body",              body: $1}
             | configuration_declaration   -> {kind: "configuration",             body: $1}
             | context_declaration         -> {kind: "context",                   body: $1}
             | semi                        -> {kind: "semi"}

# ---------------------------------------------------------------------------
# Context clauses and selected names
# ---------------------------------------------------------------------------

library_clause := kw_library identifier (comma identifier)* semi
               -> {first: $2, rest: $3}
use_clause := kw_use selected_name (comma selected_name)* semi
           -> {first: $2, rest: $3}
context_reference_clause := kw_context selected_name semi
                         -> {name: $2}
context_declaration := kw_context identifier kw_is context_item* kw_end kw_context? identifier? semi
                    -> {name: $2, items: $4, end_label: $7}
context_item := library_clause              -> {kind: "library",            body: $1}
              | use_clause                  -> {kind: "use",                body: $1}
              | context_reference_clause    -> {kind: "context_reference",  body: $1}
              | semi                        -> {kind: "semi"}

selected_name := identifier (dot identifier)*
              -> {first: $1, rest: $2}
identifier_list := identifier (comma identifier)*
                -> {first: $1, rest: $2}

# ---------------------------------------------------------------------------
# Design units
# ---------------------------------------------------------------------------

entity_declaration := kw_entity identifier kw_is entity_declarative_item* kw_end kw_entity? identifier? semi
                   -> {name: $2, items: $4, end_label: $7}

entity_declarative_item := generic_clause         -> {kind: "generic",        body: $1}
                         | port_clause            -> {kind: "port",           body: $1}
                         | component_declaration  -> {kind: "component",      body: $1}
                         | use_clause             -> {kind: "use",            body: $1}
                         | semi                   -> {kind: "semi"}

generic_clause := kw_generic lparen generic_interface_list rparen semi
               -> {list: $3}
generic_interface_list := generic_interface_element (semi generic_interface_element)*
                       -> {first: $1, rest: $2}
generic_interface_element := identifier_list colon subtype_indication (assign expression)?  -> {kind: "value",   names: $1, subtype: $3, default: $4}
                           | package_generic_interface_element                                 -> {kind: "package", body: $1}
package_generic_interface_element := kw_package identifier kw_is kw_new selected_name generic_map_aspect?
                                  -> {name: $2, base: $5, map: $6}
generic_map_aspect := kw_generic kw_map association_list
                   -> {associations: $3}

port_clause := kw_port lparen port_interface_list rparen semi
            -> {list: $3}
port_interface_list := port_interface_element (semi port_interface_element)*
                    -> {first: $1, rest: $2}
port_interface_element := identifier_list colon signal_mode subtype_indication (assign expression)?
                       -> {names: $1, mode: $3, subtype: $4, default: $5}

signal_mode := kw_in       -> {kind: "in"}
             | kw_out      -> {kind: "out"}
             | kw_inout    -> {kind: "inout"}
             | kw_buffer   -> {kind: "buffer"}
             | kw_linkage  -> {kind: "linkage"}

architecture_body := kw_architecture identifier kw_of identifier kw_is architecture_declarative_item* kw_begin concurrent_statement* kw_end kw_architecture? identifier? semi
                  -> {name: $2, entity_name: $4, items: $6, statements: $8, end_label: $11}

architecture_declarative_item := signal_declaration                  -> {kind: "signal",                   body: $1}
                               | constant_declaration                -> {kind: "constant",                 body: $1}
                               | file_declaration                    -> {kind: "file",                     body: $1}
                               | type_declaration                    -> {kind: "type",                     body: $1}
                               | subtype_declaration                 -> {kind: "subtype",                  body: $1}
                               | component_declaration               -> {kind: "component",                body: $1}
                               | subprogram_declaration              -> {kind: "subprogram_declaration",   body: $1}
                               | subprogram_body                     -> {kind: "subprogram_body",          body: $1}
                               | package_instantiation_declaration   -> {kind: "package_instantiation",    body: $1}
                               | alias_declaration                   -> {kind: "alias",                    body: $1}
                               | use_clause                          -> {kind: "use",                      body: $1}
                               | semi                                -> {kind: "semi"}

package_declaration := kw_package identifier kw_is package_header? package_declarative_item* kw_end kw_package? identifier? semi
                    -> {name: $2, header: $4, items: $5, end_label: $8}
package_body := kw_package kw_body identifier kw_is package_body_declarative_item* kw_end kw_package? kw_body? identifier? semi
             -> {name: $3, items: $5, end_label: $9}
package_header := generic_clause
               -> {generic: $1}

package_declarative_item := subprogram_declaration              -> {kind: "subprogram_declaration",  body: $1}
                          | subprogram_body                     -> {kind: "subprogram_body",         body: $1}
                          | type_declaration                    -> {kind: "type",                    body: $1}
                          | subtype_declaration                 -> {kind: "subtype",                 body: $1}
                          | constant_declaration                -> {kind: "constant",                body: $1}
                          | signal_declaration                  -> {kind: "signal",                  body: $1}
                          | file_declaration                    -> {kind: "file",                    body: $1}
                          | component_declaration               -> {kind: "component",               body: $1}
                          | package_instantiation_declaration   -> {kind: "package_instantiation",   body: $1}
                          | view_declaration                    -> {kind: "view",                    body: $1}
                          | alias_declaration                   -> {kind: "alias",                   body: $1}
                          | use_clause                          -> {kind: "use",                     body: $1}
                          | semi                                -> {kind: "semi"}

package_body_declarative_item := subprogram_declaration   -> {kind: "subprogram_declaration",  body: $1}
                               | subprogram_body          -> {kind: "subprogram_body",         body: $1}
                               | constant_declaration     -> {kind: "constant",                body: $1}
                               | signal_declaration       -> {kind: "signal",                  body: $1}
                               | file_declaration         -> {kind: "file",                    body: $1}
                               | alias_declaration        -> {kind: "alias",                   body: $1}
                               | use_clause               -> {kind: "use",                     body: $1}
                               | semi                     -> {kind: "semi"}

package_instantiation_declaration := kw_package identifier kw_is kw_new selected_name generic_map_aspect? semi
                                  -> {name: $2, base: $5, map: $6}
view_declaration := kw_view identifier kw_of selected_name kw_is view_element+ kw_end kw_view semi
                 -> {name: $2, subtype: $4, elements: $6}
view_element := identifier colon view_mode semi
             -> {name: $1, mode: $3}
view_mode := kw_in       -> {kind: "in"}
           | kw_out      -> {kind: "out"}
           | kw_inout    -> {kind: "inout"}
           | kw_buffer   -> {kind: "buffer"}
           | kw_linkage  -> {kind: "linkage"}
alias_declaration := kw_alias identifier kw_is selected_name tick kw_converse semi
                 -> {name: $2, target: $4}

configuration_declaration := kw_configuration identifier kw_of identifier kw_is configuration_item* kw_end kw_configuration? identifier? semi
                          -> {name: $2, entity_name: $4, items: $6, end_label: $9}
configuration_item := kw_for selected_name kw_end kw_for semi  -> {kind: "for",  target: $2}
                    | use_clause                                -> {kind: "use",  body: $1}
                    | semi                                      -> {kind: "semi"}

subprogram_declaration := procedure_specification semi  -> {kind: "procedure", spec: $1}
                        | function_specification semi   -> {kind: "function",  spec: $1}

subprogram_body := procedure_specification kw_is subprogram_declarative_item* kw_begin sequential_statement* kw_end kw_procedure identifier? semi  -> {kind: "procedure", spec: $1, items: $3, statements: $5, end_label: $8}
                 | function_specification kw_is subprogram_declarative_item* kw_begin sequential_statement* kw_end kw_function identifier? semi   -> {kind: "function",  spec: $1, items: $3, statements: $5, end_label: $8}

procedure_specification := kw_procedure identifier parameter_list?
                        -> {name: $2, parameters: $3}
function_specification := kw_impure? kw_function identifier parameter_list? kw_return subtype_indication
                       -> {impure: $1, name: $3, parameters: $4, return_type: $6}

subprogram_declarative_item := variable_declaration       -> {kind: "variable",                body: $1}
                             | file_declaration           -> {kind: "file",                    body: $1}
                             | constant_declaration       -> {kind: "constant",                body: $1}
                             | type_declaration           -> {kind: "type",                    body: $1}
                             | subtype_declaration        -> {kind: "subtype",                 body: $1}
                             | subprogram_declaration     -> {kind: "subprogram_declaration",  body: $1}
                             | subprogram_body            -> {kind: "subprogram_body",         body: $1}
                             | use_clause                 -> {kind: "use",                     body: $1}
                             | semi                       -> {kind: "semi"}

parameter_list := lparen parameter_interface_element (semi parameter_interface_element)* rparen
               -> {first: $2, rest: $3}
parameter_interface_element := identifier_list colon parameter_mode? subtype_indication (assign expression)?
                            -> {names: $1, mode: $3, subtype: $4, default: $5}

parameter_mode := kw_in     -> {kind: "in"}
                | kw_out    -> {kind: "out"}
                | kw_inout  -> {kind: "inout"}

# ---------------------------------------------------------------------------
# Declarations and types
# ---------------------------------------------------------------------------

signal_declaration := kw_signal identifier_list colon subtype_indication (assign expression)? semi
                   -> {names: $2, subtype: $4, default: $5}
constant_declaration := kw_constant identifier_list colon subtype_indication assign expression semi
                     -> {names: $2, subtype: $4, value: $6}
variable_declaration := kw_variable identifier_list colon subtype_indication (assign expression)? semi
                    -> {names: $2, subtype: $4, default: $5}
file_declaration := kw_file identifier_list colon subtype_indication (kw_open expression)? kw_is expression semi
                 -> {names: $2, subtype: $4, open_mode: $5, filename: $7}
subtype_declaration := kw_subtype identifier kw_is subtype_indication semi
                    -> {name: $2, subtype: $4}
component_declaration := kw_component identifier kw_is? generic_clause? port_clause? kw_end kw_component? identifier? semi
                     -> {name: $2, generic: $4, port: $5, end_label: $8}

type_declaration := kw_type identifier kw_is type_definition semi
                 -> {name: $2, definition: $4}
type_definition := enumeration_type_definition  -> {kind: "enumeration", body: $1}
                 | array_type_definition         -> {kind: "array",       body: $1}
                 | record_type_definition        -> {kind: "record",      body: $1}

enumeration_type_definition := lparen identifier (comma identifier)* rparen
                            -> {first: $2, rest: $3}
array_type_definition := kw_array lparen discrete_range rparen kw_of subtype_indication
                     -> {index_range: $3, element_subtype: $6}
record_type_definition := kw_record record_element_declaration+ kw_end kw_record
                      -> {elements: $2}
record_element_declaration := identifier_list colon subtype_indication semi
                           -> {names: $1, subtype: $3}

subtype_indication := selected_name constraint?
                  -> {type_mark: $1, constraint: $2}
constraint := range_constraint  -> {kind: "range", body: $1}
           | index_constraint    -> {kind: "index", body: $1}
range_constraint := kw_range range_expression
                 -> {range: $2}
index_constraint := lparen discrete_range (comma discrete_range)* rparen
                 -> {first: $2, rest: $3}
discrete_range := range_expression                                  -> {kind: "range",        body: $1}
                | attribute_name                                     -> {kind: "attribute",    body: $1}
                | selected_name                                      -> {kind: "name",         body: $1}
                | subtype_indication kw_range range_expression       -> {kind: "subtype_range", subtype: $1, range: $3}
                | subtype_indication kw_range box                    -> {kind: "subtype_box",   subtype: $1}

range_expression := expression kw_to expression       -> {kind: "to",     low: $1, high: $3}
                  | expression kw_downto expression   -> {kind: "downto", high: $1, low: $3}

# ---------------------------------------------------------------------------
# Concurrent statements
# ---------------------------------------------------------------------------

concurrent_statement := concurrent_signal_assignment_statement   -> {kind: "signal_assignment",      body: $1}
                      | assert_statement                          -> {kind: "assert",                 body: $1}
                      | process_statement                         -> {kind: "process",                body: $1}
                      | component_instantiation_statement         -> {kind: "component_instantiation", body: $1}
                      | generate_statement                        -> {kind: "generate",               body: $1}
                      | block_statement                           -> {kind: "block",                  body: $1}
                      | semi                                      -> {kind: "semi"}

concurrent_signal_assignment_statement := target lte signal_assignment_rhs semi
                                       -> {target: $1, rhs: $3}
target := selected_name actual_parameter_part?              -> {kind: "name",      name: $1, params: $2}
        | lparen target (comma target)+ rparen              -> {kind: "aggregate", first: $2, rest: $3}

component_instantiation_statement := identifier colon instantiated_unit generic_map_aspect? port_map_aspect? semi
                                  -> {label: $1, unit: $3, generic_map: $4, port_map: $5}
instantiated_unit := selected_name                          -> {kind: "component",     name: $1}
                   | kw_entity selected_name                 -> {kind: "entity",        name: $2}
                   | kw_configuration selected_name          -> {kind: "configuration", name: $2}
port_map_aspect := kw_port kw_map association_list
                -> {associations: $3}
association_list := lparen association_element (comma association_element)* rparen
                 -> {first: $2, rest: $3}
association_element := (identifier arrow)? actual_part
                    -> {formal: $1, actual: $2}
actual_part := expression  -> {kind: "expression", body: $1}
            | kw_open      -> {kind: "open"}

generate_statement := (identifier colon)? kw_for identifier kw_in discrete_range kw_generate concurrent_statement* kw_end kw_generate semi  -> {kind: "for", label: $1, var: $3, range: $5, statements: $7}
                    | (identifier colon)? kw_if expression kw_generate concurrent_statement* kw_end kw_generate semi                          -> {kind: "if",  label: $1, condition: $3, statements: $5}

block_statement := identifier colon kw_block (kw_is architecture_declarative_item*)? kw_begin concurrent_statement* kw_end kw_block identifier? semi
                -> {label: $1, items: $4, statements: $6, end_label: $9}

# ---------------------------------------------------------------------------
# Process and sequential statements
# ---------------------------------------------------------------------------

process_statement := process_label? kw_process sensitivity_clause? kw_is? process_declarative_item* kw_begin sequential_statement* kw_end kw_process identifier? semi
                  -> {label: $1, sensitivity: $3, items: $5, statements: $7, end_label: $10}
process_label := identifier colon
              -> {name: $1}
sensitivity_clause := lparen sensitivity_list rparen
                  -> {list: $2}
sensitivity_list := selected_name (comma selected_name)*
                 -> {first: $1, rest: $2}

process_declarative_item := variable_declaration       -> {kind: "variable",                body: $1}
                          | file_declaration           -> {kind: "file",                    body: $1}
                          | constant_declaration       -> {kind: "constant",                body: $1}
                          | type_declaration           -> {kind: "type",                    body: $1}
                          | subtype_declaration        -> {kind: "subtype",                 body: $1}
                          | subprogram_declaration     -> {kind: "subprogram_declaration",  body: $1}
                          | subprogram_body            -> {kind: "subprogram_body",         body: $1}
                          | use_clause                 -> {kind: "use",                     body: $1}
                          | semi                       -> {kind: "semi"}

sequential_statement := signal_assignment_statement      -> {kind: "signal_assignment",   body: $1}
                      | variable_assignment_statement    -> {kind: "variable_assignment", body: $1}
                      | if_statement                     -> {kind: "if",                  body: $1}
                      | case_statement                   -> {kind: "case",                body: $1}
                      | loop_statement                   -> {kind: "loop",                body: $1}
                      | exit_statement                   -> {kind: "exit",                body: $1}
                      | wait_statement                   -> {kind: "wait",                body: $1}
                      | assert_statement                 -> {kind: "assert",              body: $1}
                      | report_statement                 -> {kind: "report",              body: $1}
                      | null_statement                   -> {kind: "null"}
                      | return_statement                 -> {kind: "return",              body: $1}
                      | procedure_call_statement         -> {kind: "procedure_call",      body: $1}
                      | semi                             -> {kind: "semi"}

signal_assignment_statement := target lte signal_assignment_rhs semi
                            -> {target: $1, rhs: $3}
variable_assignment_statement := target assign expression semi
                              -> {target: $1, value: $3}
procedure_call_statement := selected_name actual_parameter_part? semi
                         -> {name: $1, params: $2}
actual_parameter_part := lparen actual_parameter_element (comma actual_parameter_element)* rparen
                     -> {first: $2, rest: $3}
actual_parameter_element := association_element  -> {kind: "association",     body: $1}
                          | range_expression      -> {kind: "range_expression", body: $1}
signal_assignment_rhs := expression (kw_when expression kw_else expression (kw_when expression kw_else expression)*)?
                      -> {value: $1, conditional: $2}

if_statement := kw_if expression kw_then sequential_statement* (kw_elsif expression kw_then sequential_statement*)* (kw_else sequential_statement*)? kw_end kw_if semi
             -> {condition: $2, then_body: $4, elsif_branches: $5, else_body: $6}

case_statement := kw_case expression kw_is case_statement_alternative+ kw_end kw_case semi
               -> {value: $2, alternatives: $4}
case_statement_alternative := kw_when choices arrow sequential_statement*
                           -> {choices: $2, body: $4}
choices := choice (bar choice)*
        -> {first: $1, rest: $2}
choice := expression  -> {kind: "expression", body: $1}
        | kw_others   -> {kind: "others"}

loop_statement := kw_while expression kw_loop sequential_statement* kw_end kw_loop semi                                  -> {kind: "while",   condition: $2, body: $4}
                | kw_for identifier kw_in discrete_range kw_loop sequential_statement* kw_end kw_loop semi              -> {kind: "for",     var: $2, range: $4, body: $6}
                | kw_loop sequential_statement* kw_end kw_loop semi                                                       -> {kind: "infinite", body: $2}

exit_statement := kw_exit (kw_when expression | identifier (kw_when expression)?)? semi
               -> {condition_or_label: $2}
wait_statement := kw_wait (kw_for expression)? semi
               -> {timeout: $2}
assert_statement := kw_assert expression (kw_report expression)? (kw_severity expression)? semi
                 -> {condition: $2, report: $3, severity: $4}
report_statement := kw_report expression (kw_severity expression)? semi
                 -> {message: $2, severity: $3}
null_statement := kw_null semi
return_statement := kw_return expression? semi
                -> {value: $2}

# ---------------------------------------------------------------------------
# Expressions
# ---------------------------------------------------------------------------

expression := relation (logical_operator relation)*
           -> {type: "binop_chain", level: "logical",      lhs: $1, rest: $2}
relation := simple_expression (relational_operator simple_expression)?
         -> {type: "binop_chain", level: "relational",   lhs: $1, rest: $2}
# NOTE: the iteration-lead operator alternations were lifted into the
# named rules `adding_operator` / `multiplying_operator` (vhdl's own
# `logical_operator`/`relational_operator` `{kind:…}` idiom). An inline
# alternation `( a | b )` as the lead element of a `( … term )*`
# iteration corrupted the positional model so `rest:$N` emitted
# `<invalid_sequence_access>` (the systemic inline-alternation-$N defect
# class; same as RTL-CE-0001 / SVPP-0001 / RTL-FE-0001). The leading
# `(plus | minus)?` sign is NOT an iteration lead and is empirically
# unaffected — left as-is.
simple_expression := (plus | minus)? term (adding_operator term)*
                  -> {type: "binop_chain", level: "additive",     sign: $1, lhs: $2, rest: $3}
term := factor (multiplying_operator factor)*
     -> {type: "binop_chain", level: "multiplicative", lhs: $1, rest: $2}
factor := primary (power primary)?
       -> {type: "binop_chain", level: "power",        lhs: $1, rest: $2}

primary := literal                                  -> {kind: "literal",        body: $1}
         | aggregate                                 -> {kind: "aggregate",      body: $1}
         | attribute_name                            -> {kind: "attribute_name", body: $1}
         | selected_name actual_parameter_part?      -> {kind: "function_call",  name: $1, params: $2}
         | selected_name                             -> {kind: "name",           body: $1}
         | lparen expression rparen                  -> {kind: "parens",         expr: $2}
         | kw_not primary                            -> {kind: "not",            expr: $2}

attribute_name := selected_name actual_parameter_part? tick identifier actual_parameter_part?
              -> {prefix: $1, prefix_params: $2, attribute: $4, attribute_params: $5}

aggregate := lparen aggregate_choice_list arrow expression (comma aggregate_element_association)* rparen          -> {kind: "named_first",       first_choices: $2, first_value: $4, rest: $5}
           | lparen expression comma aggregate_element_association (comma aggregate_element_association)* rparen   -> {kind: "positional_first",  first_value: $2, second: $4, rest: $5}
aggregate_element_association := aggregate_choice_list arrow expression   -> {kind: "named",      choices: $1, value: $3}
                               | expression                                -> {kind: "positional", value: $1}
aggregate_choice_list := aggregate_choice (bar aggregate_choice)*
                     -> {first: $1, rest: $2}
aggregate_choice := kw_others           -> {kind: "others"}
                  | selected_name        -> {kind: "name",       body: $1}
                  | decimal_literal      -> {kind: "decimal",    body: $1}
                  | character_literal    -> {kind: "character",  body: $1}
                  | string_literal       -> {kind: "string",     body: $1}

logical_operator := kw_and   -> {kind: "and"}
                  | kw_or    -> {kind: "or"}
                  | kw_xor   -> {kind: "xor"}
                  | kw_nand  -> {kind: "nand"}
                  | kw_nor   -> {kind: "nor"}
                  | kw_xnor  -> {kind: "xnor"}

relational_operator := equal        -> {kind: "eq"}
                     | slash_equal  -> {kind: "ne"}
                     | lt           -> {kind: "lt"}
                     | lteq         -> {kind: "le"}
                     | gt           -> {kind: "gt"}
                     | gteq         -> {kind: "ge"}

adding_operator := plus      -> {kind: "plus"}
                 | minus     -> {kind: "minus"}
                 | ampersand -> {kind: "concat"}

multiplying_operator := star   -> {kind: "mul"}
                      | slash  -> {kind: "div"}
                      | kw_mod -> {kind: "mod"}
                      | kw_rem -> {kind: "rem"}

literal := physical_literal       -> {kind: "physical",     body: $1}
         | decimal_literal         -> {kind: "decimal",      body: $1}
         | based_literal           -> {kind: "based",        body: $1}
         | bit_string_literal      -> {kind: "bit_string",   body: $1}
         | string_literal          -> {kind: "string",       body: $1}
         | character_literal       -> {kind: "character",    body: $1}

physical_literal := trivia /[0-9][0-9_]*(?:\.[0-9][0-9_]*)?[ \t\r\n]+(?:fs|ps|ns|us|ms|sec|min|hr)\b/
decimal_literal := unsigned_number
                -> {value: $1}
based_literal := unsigned_number hash based_value hash
              -> {base: $1, value: $3}
based_value := /[0-9A-Fa-f_]+/
bit_string_literal := trivia /[0-9]*[bBoOxX]"[0-9A-Fa-f_xXzZ]+"/

# ---------------------------------------------------------------------------
# Lexical
# ---------------------------------------------------------------------------

identifier := trivia /[A-Za-z][A-Za-z0-9_]*/

unsigned_number := trivia /[0-9]+/
string_literal := trivia /"(?:[^"\\]|\\.)*"/
character_literal := trivia /'(?:[^'\\]|\\.)'/

@branch_policy: priority_first
@priority: [32, 1]
trivia := (white_space | line_comment)*
white_space := /[ \t\r\n]+/
line_comment := /--[^\n]*(\n|$)/

semi := trivia /;/
comma := trivia /,/
colon := trivia /:/
dot := trivia /\./
bar := trivia /\|/
lparen := trivia /\(/
rparen := trivia /\)/
box := trivia /<>/
tick := trivia /'/
arrow := trivia /=>/
assign := trivia /:=/
lte := trivia /<=/

plus := trivia /\+/
minus := trivia /-/
star := trivia /\*/
slash := trivia /\//
ampersand := trivia /&/
power := trivia /\*\*/
equal := trivia /=/
slash_equal := trivia /\/=/
lt := trivia /</
lteq := trivia /<=/
