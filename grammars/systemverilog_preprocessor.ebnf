# systemverilog_preprocessor.ebnf
#
# Initial SystemVerilog preprocessor grammar seed.
# Scope for this first increment:
# - Core directive parsing (`define`, `undef`, `include`, `ifdef` family)
# - Timescale/default-nettype/celldefine directives
# - Nested conditional-compilation blocks
# - Macro formal/default argument syntax
# - Macro body primitives for token-paste and stringize
#
# Notes:
# - This grammar is intentionally line-oriented and deterministic.
# - Non-directive source lines are captured as passthrough text.

systemverilog_preprocessor_file := pp_item*
-> {type: "systemverilog_preprocessor_file", items: $1}

pp_item := pp_define
         | pp_undef
         | pp_include
         | pp_timescale
         | pp_default_nettype
         | pp_celldefine
         | pp_endcelldefine
         | pp_conditional
         | pp_non_directive_line
         | pp_blank_line

# ---------------------------------------------------------------------------
# Core directives
# ---------------------------------------------------------------------------

pp_define := kw_define macro_name macro_formals? macro_body? newline?
pp_undef := kw_undef macro_name directive_comment_tail newline?
pp_include := kw_include include_path directive_comment_tail newline?
pp_timescale := kw_timescale time_literal slash time_literal directive_comment_tail newline?
pp_default_nettype := kw_default_nettype nettype_value directive_comment_tail newline?
pp_celldefine := kw_celldefine directive_comment_tail newline?
pp_endcelldefine := kw_endcelldefine directive_comment_tail newline?

include_path := quoted_string
              | angle_path

nettype_value := identifier
               | kw_none

time_literal := unsigned_number time_unit

# ---------------------------------------------------------------------------
# Conditional-compilation blocks
# ---------------------------------------------------------------------------

pp_conditional := pp_if_branch pp_elsif_branch* pp_else_branch? pp_endif

pp_if_branch := (kw_ifdef | kw_ifndef) macro_name directive_tail? newline pp_item*
pp_elsif_branch := kw_elsif condition_expr newline pp_item*
pp_else_branch := kw_else directive_tail? newline pp_item*
pp_endif := kw_endif directive_tail? newline?

condition_expr := condition_atom+
condition_atom := macro_token_paste
                | macro_stringize
                | macro_reference
                | condition_text
                | lparen
                | rparen
                | comma
                | question
                | colon
                | logical_or
                | logical_and
                | bang

condition_text := inline_trivia /[^`(),?:!|&\r\n]+/

# ---------------------------------------------------------------------------
# Macro declaration support
# ---------------------------------------------------------------------------

macro_formals := lparen macro_formal (comma macro_formal)* rparen
macro_formal := macro_name (assign macro_default_value)?

macro_default_value := macro_default_atom+
macro_default_atom := macro_token_paste
                    | macro_stringize
                    | macro_reference
                    | macro_default_text
                    | lparen
                    | rparen
                    | question
                    | colon

macro_default_text := inline_trivia /[^`(),?:\r\n]+/

macro_body := macro_body_fragment+
macro_body_fragment := macro_token_paste
                     | macro_stringize
                     | macro_reference
                     | macro_body_text
                     | lparen
                     | rparen
                     | comma
                     | question
                     | colon

macro_body_text := inline_trivia /[^`(),?:\r\n]+/
macro_reference := bt_identifier
macro_token_paste := inline_trivia /``/
macro_stringize := inline_trivia /`"/

# ---------------------------------------------------------------------------
# Passthrough lines
# ---------------------------------------------------------------------------

pp_non_directive_line := non_directive_text newline?
pp_blank_line := newline
non_directive_text := inline_trivia /[^`\r\n][^\r\n]*/
@sample: " "
directive_tail := inline_trivia /[^\r\n]+/
@sample: " "
directive_comment_tail := inline_trivia line_comment?

# ---------------------------------------------------------------------------
# Identifiers and literals
# ---------------------------------------------------------------------------

macro_name := identifier
identifier := inline_trivia /[a-zA-Z_][a-zA-Z0-9_$]*/
bt_identifier := inline_trivia /`[a-zA-Z_][a-zA-Z0-9_$]*/

unsigned_number := inline_trivia /[0-9][0-9_]*/
quoted_string := inline_trivia /"([^"\\]|\\.)*"/
angle_path := inline_trivia /<[^>\r\n]+>/
time_unit := inline_trivia /(s|ms|us|ns|ps|fs)\b/

# ---------------------------------------------------------------------------
# Trivia and punctuation
# ---------------------------------------------------------------------------

inline_trivia := (space_or_tab | block_comment)*
trivia := (space_or_tab | line_comment | block_comment)*
space_or_tab := /[ \t]+/
line_comment := /\/\/[^\r\n]*/
block_comment := /\/\*([^*]|\*+[^*\/])*\*+\//

newline := inline_trivia /\r?\n/

slash := inline_trivia "/"
assign := inline_trivia "="
comma := inline_trivia ","
colon := inline_trivia ":"
question := inline_trivia "?"
bang := inline_trivia "!"
logical_or := inline_trivia "||"
logical_and := inline_trivia "&&"
lparen := inline_trivia "("
rparen := inline_trivia ")"

# ---------------------------------------------------------------------------
# Directive keywords
# ---------------------------------------------------------------------------

kw_define := inline_trivia /`define\b/
kw_undef := inline_trivia /`undef\b/
kw_include := inline_trivia /`include\b/
kw_ifdef := inline_trivia /`ifdef\b/
kw_ifndef := inline_trivia /`ifndef\b/
kw_elsif := inline_trivia /`elsif\b/
kw_else := inline_trivia /`else\b/
kw_endif := inline_trivia /`endif\b/
kw_timescale := inline_trivia /`timescale\b/
kw_default_nettype := inline_trivia /`default_nettype\b/
kw_celldefine := inline_trivia /`celldefine\b/
kw_endcelldefine := inline_trivia /`endcelldefine\b/
kw_none := inline_trivia /none\b/
