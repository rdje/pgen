# ===================================================================
# systemverilog.ebnf
# ===================================================================
# Active profile-aware IEEE 1800 SystemVerilog grammar.
#
# This file is the promoted single-file grammar used by the normal HDL
# flow. It carries the clause-derived dual-profile surface for:
#   - sv_2017 from docs/systemverilog/2017/md/section-41-data-read-api.md
#   - sv_2023 from docs/systemverilog/2023/md/section-Annex_A-normative-formal-syntax.md
#
# 2026-04-25 REFACTOR — RECONNECTION OF UNREACHABLE SUBGRAPHS
# ----------------------------------------------------------
# This grammar has been refactored to make the SystemVerilog EBNF a
# connected fanout tree where every defined rule is reachable from a
# top-level entry, while remaining IEEE 1800-2017/2023 compliant and
# LRM-faithful. Before the refactor, sv_syntax_closure_gate flagged
# 101 unreachable rules and 115 distinct unreachable branch debt
# entries. After the refactor: 1 unreachable rule (LRM mutual-
# recursion budget case for module_path_conditional_expression) and
# 0 actionable branch debt entries.
#
# RECONNECTIONS APPLIED
# ---------------------
# (1) Numeric chain
#     - integral_number, real_number, unsigned_number, binary_number,
#       octal_number, decimal_number, hex_number, fixed_point_number,
#       size, non_zero_unsigned_number now carry LRM-faithful
#       structural definitions instead of manual-regex / alias bodies.
#     - Helper rules (binary_base, binary_value, binary_digit,
#       decimal_base, decimal_digit, hex_base, hex_value, hex_digit,
#       octal_base, octal_value, octal_digit, x_digit, z_digit, exp,
#       sign, non_zero_decimal_digit, plus helper kw tokens) are now
#       part of the reach-set via the chain.
#
# (2) sv_multi_entry_root — synthetic multi-entry root
#     - Union of systemverilog_file, library_text, and
#       systemverilog_parseable_file.
#     - This is a closure-gate analysis aid that lets the gate's
#       single-entry static reachability analyzer see all three real
#       top-level entries at once. The runtime parser does NOT use it
#       as an entry; sv_parser/runtime code paths still use
#       systemverilog_file or systemverilog_parseable_file directly.
#     - Long-term tooling fix: extend ast_pipeline --entry-rule and
#       the closure-gate contract to accept a list of entries; once
#       that lands, sv_multi_entry_root can be removed.
#
# (3) Library subgraph
#     - library_text, library_description, library_declaration,
#       include_statement and helper kw_* tokens are reachable via
#       sv_multi_entry_root.
#
# (4) Parseable lane
#     - systemverilog_parseable_file, parseable_source_item are
#       reachable via sv_multi_entry_root.
#
# (5) Path-delay widening — IEEE 1800 specify-block compliance
#     - list_of_path_delay_expressions widened to LRM 5 alternatives:
#         (a) t_path_delay_expression
#         (b) trise, tfall (2-form)
#         (c) trise, tfall, tz (3-form)
#         (d) t01, t10, t0z, tz1, t1z, tz0 (6-form edge transitions)
#         (e) t01..tzx (12-form full edge matrix)
#     - Previously narrowed to alt (a) only; now full LRM coverage.
#
# (6) Triple-quoted string — SV 2023 compliance
#     - string_literal extended to also match """..."""  literals.
#     - Pragmatic compliance fix; the LRM string-escape rule chain
#       in the extracted grammar references broken helper kw_* tokens
#       (see RETIRED below), so wiring it would not actually parse
#       triple-quoted strings.
#
# (7) `| epsilon` cleanup in select / constant_select
#     - Replaced "( A | B | epsilon )" with "( A | B )?" in both
#       rules. Same accepted language, no reference to a non-existent
#       epsilon rule. Removes 2 unreachable-branch-debt entries.
#
# RULES INTENTIONALLY KEPT EVEN THOUGH STATIC ANALYZER FLAGS THEM
# ----------------------------------------------------------------
# - module_path_expression / module_path_conditional_expression:
#   LRM-faithful (mutual recursion preserved). The active grammar
#   eliminates the binary-op left-recursion via the
#   module_path_expression_operand pattern, but the mpe <-> mpe_cond
#   mutual reference is intentionally kept exactly as the LRM
#   specifies. The closure-gate static analyzer cannot trace through
#   that mutual reference and reports module_path_conditional_expression
#   unreachable. The rule IS reachable in language terms — PGEN's
#   runtime RecursionGuard handles indirect/mutual recursion — and
#   the gate contract reserves max_unreachable_rules <= 1 for this
#   budget case.
#
# RETIRED LRM RULES (REMOVED FROM THIS GRAMMAR)
# ----------------------------------------------
# The following 35 LRM-extracted rules are intentionally absent from
# this grammar because they offer no functional value:
#
# - LRM comment chain (3): comment, one_line_comment, comment_text
#   Reason: the LRM documents the lexical shape of comments, but
#   tokenization is handled at the trivia layer (line_comment,
#   block_comment, documentation_comment regex). The LRM rules are
#   documentation, not parser productions.
#
# - LRM identifier aliases (4): array_identifier, formal_identifier,
#   covergroup_variable_identifier, identifier_code
#   Reason: superseded by the active hand-rolled identifier
#   disambiguation machinery (declared_*, scoped_*, known_unscoped_*).
#
# - LRM package-scoped aliases (2): ps_class_identifier,
#   ps_or_hierarchical_tf_identifier
#   Reason: superseded by the active scoped_* equivalents.
#
# - DPI literal aliases (2): lit_DPI_C_*, lit_DPI_*
#   Reason: shadowed by manual dpi_spec_string regex.
#
# - Vestigial profile alias (1): non_zero_unsigned_number_sv_2017
#   Reason: after numeric chain reconnection, no longer referenced.
#
# - LRM string-escape chain (12 rules + 3 lit tokens): quoted_string,
#   quoted_string_sv_2023, quoted_string_item,
#   quoted_string_item_sv_2023, triple_quoted_string,
#   triple_quoted_string_sv_2023, triple_quoted_string_item,
#   triple_quoted_string_item_sv_2023, string_escape_seq,
#   string_escape_seq_sv_2023, plus the lit_quoted_*,
#   lit_triple_quoted_*, lit_token_* literal tokens.
#   Reason: the rule chain depends on helper kw_* tokens that the
#   extractor produced as broken regexes matching the literal text of
#   their LRM placeholder names (e.g., kw_any_ASCII_character_*
#   matches the text "any_ASCII_character", not an ASCII character).
#   Wiring these in would not parse any real string. Compliance for
#   triple-quoted strings is achieved through the string_literal
#   regex extension (see (6) above), not through this chain. If/when
#   the extractor is fixed to translate LRM placeholders into proper
#   character-class regexes, this chain can be revisited.
#
# - Broken extractor helper tokens (8): kw_any_ASCII_character_*,
#   kw_except_672fccd7, kw_newline_f6fd7a43, kw_token_08534f33,
#   kw_x_fc9847dc, kw_one_to_three_digit_octal_number_*,
#   kw_one_to_two_digit_hex_number_*
#   Reason: support the broken LRM string-escape chain; retire
#   alongside.
#
# - Stray helper tokens (2): kw_n_14_fa35e192, kw_n_ef7e6794
#   Reason: residual extractor output not referenced by anything kept.
#
# These retired rules remain in the file as `// `-prefixed comments
# so the rationale stays inline with the grammar; they are inert as
# far as the EBNF parser is concerned but discoverable for anyone
# reading the file.
#
# CLOSURE-GATE STATE (post-refactor)
# -----------------------------------
#   defined_rule_count:        1419
#   reachable_rules:           1418
#   unreachable_rules:         1   (module_path_conditional_expression)
#   unreachable_rule_debt:     1   (LRM mutual-recursion budget case)
#   unreachable_branch_debt:   0   distinct entries
#   unreachable_branches:      20  (metric — internal sub-quantifier
#                                   accounting; not actionable debt)
# ===================================================================




# systemverilog.ebnf
#
# Active profile-aware IEEE 1800 SystemVerilog grammar.
#
# This file is the promoted single-file grammar used by the normal HDL flow. It
# keeps stable entry rules (`systemverilog_file`, `systemverilog_parseable_file`)
# and carries the clause-derived dual-profile surface for:
# - `sv_2017` from `docs/systemverilog/2017/md/section-41-data-read-api.md`
# - `sv_2023` from `docs/systemverilog/2023/md/section-Annex_A-normative-formal-syntax.md`
#
# The profile synthesis artifacts remain alongside this file:
# - `systemverilog_lrm_profiled_generated.ebnf`
# - `systemverilog_lrm_profiled_wrapper.ebnf`
#
# The active grammar is flattened into one file because the legacy Perl EBNF
# frontend used in the current HDL pipeline does not expand `include(...)`.

@branch_policy: priority_first
@priority: [12, 3, 2, 1, 1]
@coverage_target: 4
@critical_path: true
systemverilog_file := trivia source_text trivia
                   -> {type: "systemverilog_file", source_text: $2}

# --- Multi-entry closure-gate analysis aid (NOT a runtime parse entry) ---
# Unions the three real top-level SV entries so the closure-gate static
# reachability analyzer can see the complete reach-set of the grammar.
# Placed AFTER systemverilog_file so parser generation (which defaults to
# the first defined rule) keeps `parse_full_systemverilog_file` as the
# embedding-API entry. Long-term, the closure gate should support a list
# of entries directly so this rule can be removed.
sv_multi_entry_root := systemverilog_file | library_text | systemverilog_parseable_file

@branch_policy: priority_first
@priority: [20, 6, 4, 2]
systemverilog_parseable_file := trivia parseable_source_item* trivia
                             -> {type: "systemverilog_parseable_file", items: $2}

@branch_policy: priority_first
@priority: [20, 6, 4, 2]
parseable_source_item := semi
//                        | package_import_declaration
//                        | timeunits_declaration
//                        | compiler_directive

@branch_policy: priority_first
@priority: [24, 16, 16, 12, 10, 8, 6, 4]
source_text_item := description                       -> {kind: "description", body: $1}
                  | local_parameter_declaration semi  -> {kind: "local_parameter_declaration", body: $1}
                  | parameter_declaration semi        -> {kind: "parameter_declaration", body: $1}
                  | package_import_declaration         -> {kind: "package_import_declaration", body: $1}
                  | timeunits_declaration              -> {kind: "timeunits_declaration", body: $1}
                  | compiler_directive                 -> {kind: "compiler_directive", body: $1}
                  | comment_only_source_region         -> {kind: "comment_only_source_region", body: $1}
                  | semi                               -> {kind: "semi"}

# Auto-generated by tools/extract_systemverilog_lrm_profiles.py
# Source markdowns:
# - sv_2017: /Users/richarddje/Documents/github/pgen/docs/systemverilog/2017/md/section-41-data-read-api.md
# - sv_2023: /Users/richarddje/Documents/github/pgen/docs/systemverilog/2023/md/section-Annex_A-normative-formal-syntax.md

# Shared lexical foundation

compiler_directive := trivia /`[^\r\n]*/
                   -> $2

comment_only_source_region := white_space* ( line_comment | block_comment ) ( white_space | line_comment | block_comment )*

binary_operator := plus                     -> {kind: "plus"}
                 | minus                    -> {kind: "minus"}
                 | star                     -> {kind: "star"}
                 | slash                    -> {kind: "slash"}
                 | percent                  -> {kind: "percent"}
                 | equal                    -> {kind: "equal"}
                 | not_equal                -> {kind: "not_equal"}
                 | case_equal               -> {kind: "case_equal"}
                 | case_not_equal           -> {kind: "case_not_equal"}
                 | wildcard_equal           -> {kind: "wildcard_equal"}
                 | wildcard_not_equal       -> {kind: "wildcard_not_equal"}
                 | logical_and              -> {kind: "logical_and"}
                 | logical_or               -> {kind: "logical_or"}
                 | power                    -> {kind: "power"}
                 | less_than                -> {kind: "less_than"}
                 | less_equal               -> {kind: "less_equal"}
                 | greater_than             -> {kind: "greater_than"}
                 | greater_equal            -> {kind: "greater_equal"}
                 | bitwise_and              -> {kind: "bitwise_and"}
                 | bitwise_or               -> {kind: "bitwise_or"}
                 | bitwise_xor              -> {kind: "bitwise_xor"}
                 | reduction_xnor_alt       -> {kind: "reduction_xnor_alt"}
                 | reduction_xnor           -> {kind: "reduction_xnor"}
                 | shift_right              -> {kind: "shift_right"}
                 | shift_left               -> {kind: "shift_left"}
                 | arithmetic_shift_right   -> {kind: "arithmetic_shift_right"}
                 | arithmetic_shift_left    -> {kind: "arithmetic_shift_left"}
                 | implies                  -> {kind: "implies"}
                 | iff_arrow                -> {kind: "iff_arrow"}

assignment_operator := assign                          -> {kind: "assign"}
                     | plus_assign                     -> {kind: "plus_assign"}
                     | minus_assign                    -> {kind: "minus_assign"}
                     | star_assign                     -> {kind: "star_assign"}
                     | slash_assign                    -> {kind: "slash_assign"}
                     | percent_assign                  -> {kind: "percent_assign"}
                     | and_assign                      -> {kind: "and_assign"}
                     | or_assign                       -> {kind: "or_assign"}
                     | xor_assign                      -> {kind: "xor_assign"}
                     | shift_left_assign               -> {kind: "shift_left_assign"}
                     | shift_right_assign              -> {kind: "shift_right_assign"}
                     | arithmetic_shift_left_assign    -> {kind: "arithmetic_shift_left_assign"}
                     | arithmetic_shift_right_assign   -> {kind: "arithmetic_shift_right_assign"}

constant_expression_operand := unary_operator attribute_instance* constant_primary
                                    -> {kind: "unary",   op: $1, attributes: $2, primary: $3}
                             | constant_primary
                                    -> {kind: "primary", body: $1}

constant_expression := @probe_sample: "1" constant_expression_operand ( binary_operator attribute_instance* constant_expression_operand )* ( question attribute_instance* constant_expression colon constant_expression )?
                    -> {first: $1, rest: $2, ternary: $3}

expression_operand := unary_operator attribute_instance* primary
                            -> {kind: "unary",      op: $1, attributes: $2, primary: $3}
                    | inc_or_dec_expression
                            -> {kind: "inc_or_dec", body: $1}
                    | primary
                            -> {kind: "primary",    body: $1}

expression_base := tagged_union_expression
                        -> {kind: "tagged_union",   body: $1}
                | expression_operand ( binary_operator attribute_instance* expression_operand )*
                        -> {kind: "operand_chain",  first: $1, rest: $2}
                | lparen operator_assignment rparen
                        -> {kind: "paren_op_assign", body: $2}

expression := @probe_sample: "1" expression_base -> {kind: "base",        body: $1}
            | inside_expression                  -> {kind: "inside",      body: $1}
            | conditional_expression             -> {kind: "conditional", body: $1}

identifier := escaped_identifier | simple_identifier

non_keyword_identifier := !reserved_non_keyword_identifier identifier
                       -> $2

declaration_identifier := non_keyword_identifier

callable_identifier := non_keyword_identifier

simple_identifier := trivia /[a-zA-Z_][a-zA-Z0-9_$]*/
                  -> $2

@sample: "foo"
simple_identifier_no_scope := trivia /[a-zA-Z_][a-zA-Z0-9_$]*(?![ \t\r\n]*::)/
                           -> $2

@sample: "\\foo "
escaped_identifier := trivia /\\[!-~]+/
                   -> $2

reserved_non_keyword_identifier := trivia /(?:parameter|localparam|type|context|pure|import|export|typedef|module|package|interface|program|class|checker|function|task|property|sequence|generate|modport|clocking|enum|struct|union|bit|logic|reg|byte|shortint|int|longint|integer|time|shortreal|real|realtime|string|chandle|event|signed|unsigned|void|endchecker|endclass|endfunction|endinterface|endmodule|endpackage|endprogram|endproperty|endsequence|endtask|begin|end|if|else|case|casez|casex|endcase|for|foreach|forever|repeat|while|do|wait|wait_order|disable|return|break|continue|fork|join|join_any|join_none|assert|assume|expect|randcase|randsequence)\b/

@branch_policy: priority_first
scope_free_identifier := simple_identifier_no_scope | escaped_identifier !scope_resolution

number := real_number | integral_number

integral_number := decimal_number | octal_number | binary_number | hex_number

real_number := fixed_point_number | unsigned_number ( dot unsigned_number )? exp ( sign )? unsigned_number

unsigned_number := decimal_digit ( kw_sv_rule_c82a06f6 | decimal_digit )*

string_literal := trivia /"""([^"]|"(?!""))*"""/ | trivia /"([^"\\]|\\.)*"/

unbased_unsized_literal := trivia /'(0|1|x|X|z|Z)/

binary_number := ( size )? binary_base binary_value

octal_number := ( size )? octal_base octal_value

decimal_number := unsigned_number | ( size )? decimal_base unsigned_number | ( size )? decimal_base x_digit ( kw_sv_rule_c82a06f6 )* | ( size )? decimal_base z_digit ( kw_sv_rule_c82a06f6 )*

hex_number := ( size )? hex_base hex_value

size := non_zero_unsigned_number

fixed_point_number := unsigned_number dot unsigned_number

time_literal := number time_unit

c_identifier := non_keyword_identifier

system_tf_identifier := trivia /\$[a-zA-Z0-9_$]+/

// identifier_code := trivia /[^\\r\\n]*/

// comment_text := trivia /([^*]|\*+[^*\/])*/

generate_block := kw_begin_8cbd0a74 ( colon generate_block_identifier )? generate_item* kw_end_7a92f3d2 ( colon generate_block_identifier )?
                       -> {kind: "anonymous",     label: $2, items: $3, end_label: $5}
               | generate_block_identifier colon kw_begin_8cbd0a74 ( colon generate_block_identifier )? generate_item* kw_end_7a92f3d2 ( colon generate_block_identifier )?
                       -> {kind: "labeled",       name: $1, label: $4, items: $5, end_label: $7}
               | generate_item
                       -> {kind: "generate_item", body: $1}

trivia := (white_space | line_comment | block_comment)*

white_space := /[ \t\r\n]+/

@sample: "//x\n"
line_comment := /\/\/[^\n]*(\n|$)/

block_comment := /\/\*([^*]|\*+[^*\/])*\*+\//

modport_simple_ports_declaration := port_direction modport_simple_port
                                 -> {direction: $1, port: $2}

# Profile-aware LRM-derived syntax

action_block := statement_or_null
                     -> {kind: "always",    body: $1}
              | ( statement )? kw_else_ae050f5b statement_or_null
                     -> {kind: "with_else", pass: $1, fail: $3}

always_construct := always_keyword statement
                 -> {keyword: $1, body: $2}

always_keyword := kw_always_6656018a       -> {kind: "always"}
                | kw_always_comb_a1f2a86b  -> {kind: "always_comb"}
                | kw_always_latch_23c99af9 -> {kind: "always_latch"}
                | kw_always_ff_3c7a051e    -> {kind: "always_ff"}

anonymous_program := kw_program_81d9aeea semi anonymous_program_item* kw_endprogram_6b609b1f
                  -> {items: $3}

@profiles: ["sv_2017"]
anonymous_program_item_sv_2017 := task_declaration | function_declaration | class_declaration | covergroup_declaration | class_constructor_declaration | semi

@profiles: ["sv_2023"]
anonymous_program_item_sv_2023 := task_declaration | function_declaration | class_declaration | interface_class_declaration | covergroup_declaration | class_constructor_declaration | semi

anonymous_program_item := anonymous_program_item_sv_2017 | anonymous_program_item_sv_2023

ansi_port_declaration := ( net_port_header | interface_port_header )? port_identifier unpacked_dimension* ( assign constant_expression )? | ( variable_port_header )? port_identifier variable_dimension* ( assign constant_expression )? | ( port_direction )? dot port_identifier lparen ( expression )? rparen

// array_identifier := identifier

array_manipulation_call := array_method_name attribute_instance* ( lparen list_of_arguments rparen )? ( kw_with_8fcd25a3 lparen expression rparen )?

array_method_name := method_identifier      -> {kind: "method_identifier", body: $1}
                   | kw_unique_58037c00     -> {kind: "unique"}
                   | kw_and_cffa50a3        -> {kind: "and"}
                   | kw_or_1758356d         -> {kind: "or"}
                   | kw_xor_f1922a23        -> {kind: "xor"}

array_pattern_key := constant_expression | assignment_pattern_key

array_range_expression := expression | expression colon expression | expression plus colon expression | expression minus colon expression

assert_property_statement := kw_assert_64b5daad kw_property_269fe373 lparen property_spec rparen action_block
                          -> {spec: $4, action: $6}

assertion_item := concurrent_assertion_item            -> {kind: "concurrent",            body: $1}
               | deferred_immediate_assertion_item     -> {kind: "deferred_immediate",    body: $1}

assertion_item_declaration := property_declaration -> {kind: "property", body: $1}
                            | sequence_declaration -> {kind: "sequence", body: $1}
                            | let_declaration      -> {kind: "let",      body: $1}

assertion_variable_declaration := var_data_type list_of_variable_decl_assignments semi

assignment_pattern := @sample: "'{0, 1}" tick lbrace expression ( comma expression )* rbrace
                   -> {exprs: [$3, $4::2*]}
                    | @sample: "'{x: 0}" tick lbrace structure_pattern_key colon expression ( comma structure_pattern_key colon expression )* rbrace
                    | @sample: "'{1: 0}" tick lbrace array_pattern_key colon expression ( comma array_pattern_key colon expression )* rbrace
                    | @sample: "'{2{0, 1}}" tick lbrace constant_expression lbrace expression ( comma expression )* rbrace rbrace

assignment_pattern_expression := ( assignment_pattern_expression_type )? assignment_pattern

assignment_pattern_expression_type := ps_type_identifier | ps_parameter_identifier | integer_atom_type | type_reference

assignment_pattern_key := simple_type | kw_default_7505d64a

assignment_pattern_net_lvalue := tick lbrace net_lvalue ( comma net_lvalue )* rbrace

assignment_pattern_variable_lvalue := tick lbrace variable_lvalue ( comma variable_lvalue )* rbrace

associative_dimension := lbrack data_type rbrack | lbrack star rbrack

assume_property_statement := kw_assume_661e458e kw_property_269fe373 lparen property_spec rparen action_block
                          -> {spec: $4, action: $6}

attr_name := identifier

attr_spec := attr_name ( assign constant_expression )?
          -> {name: $1, value: $2}

attribute_instance := attr_open attr_spec ( comma attr_spec )* attr_close
                   -> [$2, $3::2*]

bin_identifier := identifier

binary_base := tick ( kw_s_a0f1490a | kw_S_02aa629c )? kw_b_e9d71f5e | tick ( kw_s_a0f1490a | kw_S_02aa629c )? kw_B_ae4f281d

binary_digit := x_digit | z_digit | kw_n_0_b6589fc6 | kw_n_1_356a192b

@profiles: ["sv_2023"]
binary_module_path_operator_sv_2023 := equal | not_equal | logical_and | logical_or | bitwise_and | bitwise_or | bitwise_xor | reduction_xnor_alt | reduction_xnor

binary_module_path_operator := binary_module_path_operator_sv_2023

binary_value := binary_digit ( kw_sv_rule_c82a06f6 | binary_digit )*

bind_directive := kw_bind_6bdd4db9 bind_target_scope ( colon bind_target_instance_list )? bind_instantiation semi
                    -> {kind: "scoped", target_scope: $2, instances: $3, instantiation: $4}
               | kw_bind_6bdd4db9 bind_target_instance bind_instantiation semi
                    -> {kind: "single", target_instance: $2, instantiation: $3}

bind_instantiation := program_instantiation   -> {kind: "program",   body: $1}
                   | module_instantiation     -> {kind: "module",    body: $1}
                   | interface_instantiation  -> {kind: "interface", body: $1}
                   | checker_instantiation    -> {kind: "checker",   body: $1}

bind_target_instance := hierarchical_identifier constant_bit_select
                     -> {name: $1, bit_select: $2}

bind_target_instance_list := bind_target_instance ( comma bind_target_instance )*
                          -> [$1, $2::2*]

bind_target_scope := module_identifier    -> {kind: "module",    name: $1}
                  | interface_identifier -> {kind: "interface", name: $1}

bins_expression := variable_identifier | cover_point_identifier ( dot bin_identifier )?

