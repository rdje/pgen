# Advanced Return Annotations Test Grammar
# This grammar showcases all the enhanced return annotation features
# including nested objects, arrays, quantifiers, dot notation, and complex semantic actions

# Main entry point - parses a complete data structure
data_structure := object_def | array_def | simple_value
    -> {type: "data_structure", content: $1}

# Object definitions with complex return annotations
object_def := "{" /\s*/ property_list? /\s*/ "}"
    -> {type: "object", properties: $3 || [], source_location: {start: 1, end: 5}}

property_list := property ("," /\s*/ property)*
    -> [$1, $3*]

property := key /\s*/ ":" /\s*/ value
    -> {key: $1, value: $5, metadata: {line: 1}}

key := /\"([^\"]+)\"/ -> $1
     | /([a-zA-Z_]\w*)/ -> $1

# Array definitions with quantified collections
array_def := "[" /\s*/ element_list? /\s*/ "]"
    -> {type: "array", elements: $3 || [], count: ($3 || []).length}

element_list := value ("," /\s*/ value)*
    -> [$1, $3*]

# Values with nested return annotations
value := object_def -> {type: "nested_object", data: $1}
       | array_def -> {type: "nested_array", data: $1}  
       | simple_value -> {type: "simple", data: $1}
       | function_call -> {type: "function", data: $1}

# Function calls with complex parameter handling
function_call := /([a-zA-Z_]\w*)/ "(" /\s*/ parameter_list? /\s*/ ")"
    -> {function_name: $1, parameters: $4 || [], call_type: "function_invocation"}

parameter_list := parameter ("," /\s*/ parameter)*
    -> [$1, $3*]

parameter := value -> {param_value: $1, param_index: "auto"}

# Simple values with type annotations
simple_value := string_literal -> {type: "string", value: $1, encoding: "utf8"}
              | number_literal -> {type: "number", value: $1, numeric_type: "auto"}  
              | boolean_literal -> {type: "boolean", value: $1}

string_literal := /\"([^\"]*)\"/  -> $1

number_literal := /(-?\d+\.?\d*)/ -> $1

boolean_literal := "true" -> true
                 | "false" -> false

# Complex nested structures with ultimate dot notation
nested_access := value accessor+
    -> {base: $1, accessors: [$2*], result_type: $1.type}

accessor := "." /([a-zA-Z_]\w*)/ -> {type: "property", name: $2}
          | "[" /\s*/ /(\\d+)/ /\s*/ "]" -> {type: "index", value: $3}
          | "[" /\s*/ string_literal /\s*/ "]" -> {type: "key", value: $3}

# Quantified patterns with complex aggregations
repeated_pattern := item quantifier
    -> {pattern: $1, quantifier: $2, collection_type: "sequence"}

item := simple_value | "(" value ")"

quantifier := "*" -> {min: 0, max: "unlimited", type: "zero_or_more"}
           | "+" -> {min: 1, max: "unlimited", type: "one_or_more"}  
           | "?" -> {min: 0, max: 1, type: "optional"}
           | "{" /\s*/ /(\d+)/ /\s*/ "}" -> {min: $3, max: $3, type: "exact"}
           | "{" /\s*/ /(\d+)/ /\s*/ "," /\s*/ "}" -> {min: $3, max: "unlimited", type: "at_least"}
           | "{" /\s*/ /(\d+)/ /\s*/ "," /\s*/ /(\d+)/ /\s*/ "}" -> {min: $3, max: $7, type: "range"}

# Multi-property object with complex nesting
configuration := "config" "{" config_entry* "}"
    -> {type: "configuration", entries: [$3*], entry_count: ($3*).length, valid: true}

config_entry := config_key "=" config_value ";"
    -> {key: $1, value: $3, entry_type: "setting"}

config_key := /([a-zA-Z_]\w*)/  -> $1

config_value := simple_value -> {config_type: "simple", data: $1}
              | "[" config_value_list "]" -> {config_type: "array", data: $2}

config_value_list := config_value ("," config_value)*
    -> [$1, $3*]

# Ultimate test: deeply nested structure with all features
ultimate_structure := "ultimate" "{" ultimate_content "}"
    -> {
        structure_type: "ultimate",
        content: $3,
        metadata: {
            parser_version: "2.0",
            features_used: ["nested_objects", "quantified_arrays", "dot_notation"],
            complexity_score: 10
        }
    }

ultimate_content := ultimate_item ("," ultimate_item)*
    -> {
        primary: $1,
        additional: [$3*],
        total_items: 1 + ($3*).length,
        structure_analysis: {
            has_primary: true,
            has_additional: ($3*).length > 0,
            item_types: [$1.type, ...($3*).map(x => x.type)]
        }
    }

ultimate_item := key ":" ultimate_value
    -> {
        item_key: $1,
        item_value: $3,
        type: $3.type || "unknown",
        path: [$1]
    }

ultimate_value := simple_value -> {type: "simple", data: $1, complexity: 1}
                | "[" ultimate_array_content "]" -> {type: "array", data: $2, complexity: 3}
                | "{" ultimate_object_content "}" -> {type: "object", data: $2, complexity: 5}

ultimate_array_content := ultimate_value ("," ultimate_value)*
    -> {
        elements: [$1, $3*],
        count: 1 + ($3*).length,
        types: [$1.type, ...($3*).map(x => x.type)],
        max_complexity: Math.max($1.complexity, ...($3*).map(x => x.complexity))
    }

ultimate_object_content := ultimate_item ("," ultimate_item)*
    -> {
        properties: [$1, $3*],
        property_count: 1 + ($3*).length,
        property_names: [$1.item_key, ...($3*).map(x => x.item_key)],
        nested_complexity: $1.item_value.complexity + ($3*).reduce((sum, x) => sum + x.item_value.complexity, 0)
    }
